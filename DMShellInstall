  # 检查磁盘数量是否为 1、3 或 5
  if ! [[ ${#disks[@]} =~ ^(1|3|5)$ ]]; then
    printf "\n"
    color_printf red "dscm集群 [-dcd] 参数必须包含 1、3 或 5 块磁盘，请重新传递 -dcd 参数！"
    printf "\n"
    exit 1
  fi
  # 定义最小磁盘数量
  local min_disks
  # 获取冗余模式配置 (假设 log_disk、arch_disk、data_redun 是已定义的)
  declare -a disk_redun=(${log_disk:+"$redo_redun"} ${arch_disk:+"$arch_redun"} "$data_redun")
  # 遍历冗余模式配置，检查每个模式下的磁盘数量
  for ((x = 0; x < ${#disk_redun[@]}; x++)); do
    # 根据冗余模式设置最小磁盘数量
    case ${disk_redun[$x]} in
    1) min_disks=1 ;; # 冗余模式 1，需要至少 1 块磁盘
    2) min_disks=2 ;; # 冗余模式 2，需要至少 2 块磁盘
    *) min_disks=3 ;; # 默认冗余模式，需要至少 3 块磁盘
    esac
    # 获取当前冗余模式下的磁盘数组（假设 disk_arr 是已定义的）
    IFS=',' read -ra disk_count <<<"${disk_arr[$((x + 1))]}"
    # 检查当前冗余模式下的磁盘数量是否满足最小要求
    if ((${#disk_count[@]} < "$min_disks")); then
      printf "\n"
      color_printf red "磁盘数量 ${disk_count[*]} 不满足冗余模式 ${disk_redun[$x]} 的最小要求！"
      printf "\n"
      exit 1
    fi
  done
}
#==============================================================#
# 过滤唯一wwid磁盘
#==============================================================#
function filter_disk() {
  local fil_disk=$1 all_disks disk disk_list=() wwid
  declare -A wwids sizes
  # 获取磁盘存储大小的函数，返回值以 GB 为单位
  function disk_storage() {
    lsblk -b -o SIZE,TYPE "${1}" | awk '$2 == "disk" {print $1/1024/1024/1024 "G"}'
  }
  # 获取所有磁盘名，以 sd 或 vd 开头的磁盘
  all_disks=$(lsblk -n -o NAME | awk '/^sd|vd/ { print $1 }')
  # 解析传入的过滤磁盘列表
  IFS=',' read -ra fil_disk_arr <<<"$fil_disk"
  # 过滤磁盘列表，排除在过滤列表中的磁盘
  for disk in $all_disks; do
    if ! [[ "${fil_disk_arr[*]}" =~ $disk ]]; then
      disk_list+=("/dev/$disk")
    fi
  done
  # 获取每个磁盘的大小和 WWID
  for disk in "${disk_list[@]}"; do
    sizes[$disk]=$(disk_storage "$disk") # 获取磁盘大小
    wwid=$(get_wwid "$disk")             # 获取磁盘的 WWID
    if [[ -n $wwid && ! "${wwids[*]}" =~ $wwid ]]; then
      wwids[$disk]=$wwid # 存储 WWID 和磁盘名称
    fi
  done
  # 打印磁盘信息
  printf "\n"
  color_printf light_blue "Disk WWID" "Disk Name" "Size" # 输出表头
  printf "\n"
  for disk in "${!wwids[@]}"; do
    color_printf white "${wwids[$disk]}" "$disk" "${sizes[$disk]}" # 输出每个磁盘的信息
  done | sort -k3,3n -k2,2                                         # 按照大小升序排序，如果大小相同则按磁盘名称排序
  printf "\n"
}
#==============================================================#
# 校验 IP 和 共享磁盘
#==============================================================#
function validate_ip_disk() {
  # 定义校验标记
  CHECK_FLAG=1
  # 将 IP 地址加入到相应的数组
  function add_ip_to_array() {
    local ip_array_name="$1"
    shift
    local ip_arr=("$@")
    for ip in "${ip_arr[@]}"; do
      if [[ -n "$ip" ]]; then
        eval "$ip_array_name+=(\"\$ip\")"
      fi
    done
  }
  # 根据安装模式设置 IP 和磁盘
  case "$dm_install_mode" in
  "datawatch")
    add_ip_to_array "all_pubip_arr" "${db_pubip_arr[@]}" "${as_pubip_arr[@]}" "${sy_pubip_arr[@]}" "$dw_monitor_ip"
    add_ip_to_array "all_malip_arr" "${db_malip_arr[@]}" "${as_malip_arr[@]}" "${sy_malip_arr[@]}"
    ;;
  *)
    add_ip_to_array "all_pubip_arr" "${db_pubip_arr[@]}"
    add_ip_to_array "all_malip_arr" "${db_malip_arr[@]}"
    ;;
  esac
  # 校验 IP 地址和磁盘
  if [[ $node_num -eq 1 ]]; then
    log_print "校验IP地址和磁盘"
    # 校验服务器 IP
    check_ip_arr "PUBIP" "${all_pubip_arr[@]}"
    printf "\n"
    check_ip_arr "MALIP" "${all_malip_arr[@]}"
    if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
      # 校验共享磁盘
      check_disk
    fi
    # 判断传的业务IP和心跳IP是否有丢失
    if [[ $dm_install_mode =~ ^(datawatch|dsc|dscm)$ ]]; then
      len1=$((${#db_pubip_arr[@]} + ${#as_pubip_arr[@]} + ${#sy_pubip_arr[@]}))
      len2=${#all_malip_arr[@]}
      if [ $len1 -ne "$len2" ]; then
        printf "\n"
        color_printf red "请检查参数 -dpi，-api，-spi，-dmi，有IP地址丢失！"
        printf "\n"
        exit 1
      fi
    fi
  fi
  # 所有参数校验完成，根据 CHECK_FLAG 判断是否退出本次安装
  if [[ $CHECK_FLAG -eq 0 ]]; then
    printf "\n"
    color_printf red "参数校验不通过！请检查屏幕上输出的参数异常信息或者查看 ${dminstalllog} 文件获取异常参数信息，处理后再次校验！"
    printf "\n"
    exit 1
  fi
  # 在 dsc 或 dscm 模式下创建磁盘数组
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
    # 创建磁盘数组
    # shellcheck disable=SC2207
    disk_arr=($([[ $dm_install_mode == "dsc" ]] && echo "$dcr_disk $vote_disk" || echo "$dcr_disk") ${log_disk:+$log_disk} ${arch_disk:+$arch_disk} "$data_disk")
    # 创建 ASM 磁盘数组
    # shellcheck disable=SC2207
    asm_disk_arr=($([[ $dm_install_mode == "dsc" ]] && echo "dmdcr dmvote" || echo "dmdcrv ") ${log_disk:+dmlog} ${arch_disk:+dmarch} dmdata)
  fi
}
#==============================================================#
# 互信检查
#==============================================================#
function ssh_check() {
  local username="$1"
  shift
  # 检查是否安装了 expect
  local use_expect=false
  if command -v expect >/dev/null 2>&1; then
    use_expect=true
  fi
  # 通用 SSH 连接测试函数
  function check_ssh() {
    local ip="$1"
    if $use_expect; then
      expect -c "
set timeout 30
spawn ssh -o StrictHostKeyChecking=no -o BatchMode=yes -p $os_ssh_port ${username}@${ip} exit
expect {
  \"denied\" {
    exit 1 
  } 
  \"timed out\" {
    exit 1 
  }
  eof {
    exit 0
  }
}
expect eof
" >/dev/null 2>&1
    else
      ssh -q -o ConnectTimeout=30 -o ConnectionAttempts=5 -o PreferredAuthentications=publickey -o StrictHostKeyChecking=no -p "$os_ssh_port" "${username}"@"${ip}" exit >/dev/null 2>&1
    fi
    return $?
  }
  # 遍历每个 IP 地址并检查连接
  for ip in "$@"; do
    if ! check_ssh "$ip"; then
      echo "false"
      return 1
    fi
  done
  echo "true"
}
#==============================================================#
# SSH 互信配置函数
#==============================================================#
function ssh_trust() {
  local dest_user="$1" ssh_dir key_copy_method
  passwd=$(printf "%q" "$2")
  key_copy_method="$3" # 选择公钥复制方式: "ssh-copy-id" 或 "manual"
  shift 3
  umask 077
  # 设置 SSH 目录路径
  ssh_dir=$([[ $dest_user == "root" ]] && echo "/root/.ssh" || echo "/home/$dest_user/.ssh")
  # 如果目标路径存在，备份该路径
  if check_file "$ssh_dir"; then
    /bin/mv -f "$ssh_dir" "$ssh_dir.$current"
  fi
  # 创建 SSH 目录并设置权限
  /bin/mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"
  # 生成 SSH 密钥
  local key_path="$ssh_dir/id_rsa"
  ssh-keygen -t rsa -f "$key_path" -P '' -q
  # 定义 Expect 脚本通用模板
  function expect_script() {
    local action="$1"
    expect -c "
set timeout 30
log_user 0
spawn $action
expect {
  \"password:\" { 
    send \"$passwd\r\"; exp_continue 
  }
  \"denied\" { 
    puts \"连接失败，请检查用户名和密码。\"; exit 1 
  }
  \"added:\" {
    puts \"目标主机 $ip 互信配置成功。\"; exit 0
  }
  \"timed out\" { 
    puts \"操作超时，请检查网络连接或目标主机是否可达。\"; exit 1 
  }
  eof { 
    exit 0 
  }
}
expect eof
"
  }
  # 公钥复制逻辑
  if [[ "$key_copy_method" -eq 1 ]]; then
    # 自动添加公钥到 authorized_keys
    for ip in "$@"; do
      expect_script "ssh-copy-id -f -o StrictHostKeyChecking=no -p $os_ssh_port $dest_user@$ip"
    done
  elif [[ "$key_copy_method" -eq 2 ]]; then
    # 手动添加公钥到 authorized_keys
    cat "${key_path}.pub" >>"$ssh_dir/authorized_keys" && chmod 600 "$ssh_dir/authorized_keys"
    for ip in "$@"; do
      expect_script "ssh -q -o StrictHostKeyChecking=no -p $os_ssh_port $dest_user@$ip \"echo 'added:'\""
    done
  else
    echo "无效的公钥复制方式: $key_copy_method"
    return 1
  fi
  # 并行分发 .ssh 目录
  for ip in "${@:2}"; do
    expect_script "scp -q -o StrictHostKeyChecking=no -P $os_ssh_port -r $ssh_dir $dest_user@$ip:~"
  done
  # 恢复 SELinux 文件安全上下文（仅适用于操作系统版本 6）
  if [[ $os_version -eq 6 ]]; then
    for ip in "$@"; do
      expect_script "ssh -q -o StrictHostKeyChecking=no -p $os_ssh_port $dest_user@$ip \"/sbin/restorecon -RF $ssh_dir\""
    done
  fi
}
#==============================================================#
# 卸载目标服务器iso镜像和创建目录
#==============================================================#
function recreate_dir() {
  local target_ip="$1" # 获取目标 IP 地址
  # 导出函数以供其他进程使用
  export -f run_cmd
  exec_ssh_cmd "$target_ip" "$(declare -f run_cmd)
# 获取挂载信息
mount_output=\$(run_cmd mount)
# 遍历挂载信息并卸载包含 'dm8' 或 'dm9' 的设备
while IFS= read -r line; do
  if [[ \"\$line\" =~ dm8|dm9 ]]; then
    # 提取设备名并卸载
    device=\$(echo \"\$line\" | awk '{print \$(NF-3)}')
    run_cmd umount -f \"\$device\"
  fi
done <<<\"\$mount_output\"
# 删除目标目录并重新创建
if [[ -e ${software_dir} || -d ${software_dir} ]]; then
  run_cmd rm -rf ${software_dir}
fi
mkdir -p ${software_dir}
"
}
#==============================================================#
# 数据库启动函数
#==============================================================#
function db_service_cmd() {
  if [[ $os_version -eq 6 ]]; then
    local db_service_path=/etc/rc.d/init.d # RHEL/CentOS 6 使用的服务路径
  else
    local db_service_path=$env_dm_home/bin # 其他系统版本使用自定义路径
  fi
  # 定义数据库启动的全局变量
  case $dm_install_mode in
  "single" | "datawatch")
    # 数据守护模式，设置服务命令
    DMW_START_CMD="$db_service_path/DmWatcherService${dw_group_name} start"
    DMS_START_CMD="$db_service_path/DmService${db_name} start"
    DMM_START_CMD="$db_service_path/DmMonitorService$dw_group_name start"
    DMW_STOP_CMD="$db_service_path/DmWatcherService${dw_group_name} stop"
    DMS_STOP_CMD="$db_service_path/DmService${db_name} stop"
    DMM_STOP_CMD="$db_service_path/DmMonitorService$dw_group_name stop"
    DMS_RESTART_CMD="$db_service_path/DmService${db_name} restart"
    ;;
  "dsc" | "dscm")
    # DSC 集群模式，设置服务命令
    DM_CSS_SERVICE="DmCSSServiceCss"
    if [[ $dm_install_mode == "dsc" ]]; then
      DM_ASM_SERVICE="DmASMSvrServiceAsmsvr" # 如果是 dsc，使用 DM_ASM_SERVICE
    else
      DM_ASM_SERVICE="DmASMSvrmServiceAsmsvr" # 如果是 dscm，使用不同的服务命令
    fi
    DM_DB_SERVICE="DmService${dsc_db_name}" # 设置数据库服务命令
    # 各个服务的启动命令
    CSS_START_CMD="$db_service_path/DmCSSServiceCss start"    # CSS服务启动
    ASMSVR_START_CMD="$db_service_path/$DM_ASM_SERVICE start" # ASM实例服务启动
    DB_START_CMD="$db_service_path/$DM_DB_SERVICE start"      # DB服务启动
    # CSS 服务停止命令
    DMC_STOP_CMD="$db_service_path/DmCSSServiceCss stop" # CSS服务停止
    ;;
  esac
}
