      exec_ssh_cmd "$ip" "$(declare -f sftp_cmd)
sftp_cmd \"${sftp_server_ip}\" \"$sftp_server_port\" \"${sftp_username}\" \"${sftp_passwd}\" \"${sftp_dir}\" \"${software_dir}\" \"DOWN\"
"
    done
  else
