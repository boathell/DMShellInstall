#==============================================================#
# 默认生成一个12位的密码
#==============================================================#
function gen_password() {
  local password=${1:-} # 如果提供密码，则校验；如果没有提供，则生成
  local flag=${2:-}
  # 定义规则关联数组
  declare -A rules=(
    ["A"]="^.{9,}$"
    ["A_DESC"]="密码长度至少为9位"
    ["B"]="[a-z]"
    ["B_DESC"]="密码中必须包含至少一个小写字母"
    ["C"]="[A-Z]"
    ["C_DESC"]="密码中必须包含至少一个大写字母"
    ["D"]="[0-9]"
    ["D_DESC"]="密码中必须包含至少一个数字"
    ["E"]="[^[:alnum:]]"
    ["E_DESC"]="密码中必须包含至少一个特殊字符"
  )
  local is_valid=0 # 标记密码是否有效
  while [[ $is_valid -eq 0 ]]; do
    # 如果没有提供密码，生成一个密码
    if [[ -z $password ]]; then
      password=$(
        shuf -e \
          "$(tr -dc '[:upper:]' </dev/urandom | head -c 3)" \
          "$(tr -dc '[:lower:]' </dev/urandom | head -c 3)" \
          "$(tr -dc '0-9' </dev/urandom | head -c 4)" \
          "$(tr -dc '@#%&*_+=' </dev/urandom | head -c 2)" |
          tr -d ' ' |
          fold -w1 |
          shuf |
          tr -d '\n'
      )
    fi
    # 校验密码是否符合规则
    is_valid=1 # 先假设密码是有效的
    for rule in "${!rules[@]}"; do
      # 跳过描述规则
      if [[ $rule =~ _DESC$ ]]; then
        continue
      fi
      # 获取当前规则的描述
      local desc="${rules[${rule}_DESC]}"
      # 检查密码是否符合当前规则
      if ! [[ $password =~ ${rules[$rule]} ]]; then
        is_valid=0
        ARG_CHECK_FLAG=0
        printf "\n"
        color_printf red " 请检查参数[ $flag ] ,密码不符合要求（长度需要9位以上，包含大小写字母，数字，特殊符号）：$desc"
        printf "\n"
        break # 一旦有规则不通过，立即退出循环重新生成
      fi
    done
  done
  # 返回最终生成的符合规则的密码
  if [[ -z $flag ]]; then
    echo "$password"
  fi
}
#==============================================================#
