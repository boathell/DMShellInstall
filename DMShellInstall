#==============================================================#
# 打印环境信息
#==============================================================#
function print_sysinfo() {
  log_print "打印系统信息"
  function print_cpu_info() {
    # 保存当前语言环境
    current_lang=$LANG
    # 临时切换到英文环境
    export LANG="en_US.UTF-8"
    # 定义关联数组的键的顺序
    keys=("A" "B" "C" "D")
    # 保存要提取的信息的关键词
    declare -A keywords=(
      ["A"]="$(grep </proc/cpuinfo "model name" | head -n 1 | awk -F ': ' '{print $2}')"
      ["A_DESC"]="型号名称                "
      ["B"]="$(grep </proc/cpuinfo "physical id" | sort | uniq | wc -l)"
      ["B_DESC"]="物理 CPU 个数           "
      ["C"]="$(grep </proc/cpuinfo "core id" | sort -u | wc -l)"
      ["C_DESC"]="每个物理 CPU 的逻辑核数 "
      ["D"]="$(grep -c "processor" /proc/cpuinfo)"
      ["D_DESC"]="系统的 CPU 线程数       "
    )
    # 循环提取信息并按顺序打印
    for key in "${keys[@]}"; do
      desc="${keywords[${key}_DESC]}"
      value="${keywords[$key]}"
      color_printf white "$desc ：$value"
    done
    # 恢复原来的语言环境
    export LANG="$current_lang"
  }
  # 服务器时间
  color_printf blue "服务器时间: "
  printf "\n"
  date
  # 操作系统版本
  printf "\n"
  color_printf blue "操作系统版本: "
  printf "\n"
  if check_file /etc/os-release; then
    cat /etc/os-release
  elif check_file /etc/system-release; then
    cat /etc/system-release
  elif check_file /etc/redhat-release; then
    cat /etc/redhat-release
  fi
  # 内核信息
  printf "\n"
  color_printf blue "内核信息: "
  printf "\n"
  cat /proc/version
  # 服务器属性
  printf "\n"
  color_printf blue "服务器属性: "
  printf "\n"
  virt-what
  # cpu信息
  printf "\n"
  color_printf blue "cpu信息: "
  printf "\n"
  print_cpu_info
  # 内存信息
  printf "\n"
  color_printf blue "内存信息: "
  printf "\n"
  free -m && free -h
  # 挂载信息
  printf "\n"
  color_printf blue "挂载信息: "
  printf "\n"
  grep </etc/fstab -E -v '^#|^\*#|^$'
  # 目录信息
  printf "\n"
  color_printf blue "目录信息: "
  printf "\n"
  df -h
}
#==============================================================#
# 配置YUM源
#==============================================================#
function conf_yum() {
  # 截取ISO镜像挂载路径
  local mountPatch=
  # 获取 mount 命令的输出
  mount_output=$(run_cmd mount)
  # 遍历每一行
  while IFS= read -r line; do
    # 判断当前行是否包含 iso9660，且不包含 dm8、dm9 和 /run/media
    if [[ "$line" =~ iso9660 ]] && ! [[ "$line" =~ dm8|dm9|/run/media ]]; then
      # 从挂载信息中提取设备名（倒数第三列）
      mountPatch=$(echo "$line" | awk '{print $(NF-3)}' | tail -n 1)
    fi
  done <<<"$mount_output"
  # 判断os镜像是否挂载
  if [[ -z $mountPatch ]]; then
    printf "\n"
    color_printf red "操作系统 ISO 镜像未挂载，且 -iso 参数配置为 Y，请先挂载操作系统镜像！"
    printf "\n"
    exit 1
  fi
  log_print "打印 yum 配置文件内容"
  local repo_path=/etc/yum.repos.d
  local repo_name="${repo_path}/local.repo"
  local config
  # 避免Linux主机提示注册
  [[ -e /etc/yum/pluginconf.d/subscription-manager.conf ]] && run_cmd sed -i 's/enabled=1/enabled=0/' /etc/yum/pluginconf.d/subscription-manager.conf
  # 避免Kyli/openEuler主机提示注册
  [[ -e /etc/yum/pluginconf.d/debuginfo-install.conf ]] && run_cmd sed -i 's/enabled=1/enabled=0/' /etc/yum/pluginconf.d/debuginfo-install.conf
  # 备份原有的yum配置文件
  run_cmd mkdir -p ${repo_path}/bak && run_cmd mv -f ${repo_path}/* ${repo_path}/bak >/dev/null 2>&1
  # 根据不同版本号创建本地YUM源配置文件
  # 定义基础OS源
  function baseos() {
    config=$(
      cat <<EOF
[BaseOS]
name=BaseOS
baseurl=$baseurl_file
enabled=1
gpgcheck=0
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee "$repo_name"
  }
  # 定义软件源
  function appstream() {
    config=$(
      cat <<EOF

[AppStream]
name=AppStream
baseurl=file://$mountPatch/AppStream
enabled=1
gpgcheck=0
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee -a "$repo_name"
  }
  # 适配各种OS系统配置YUM源
  case $os_flag in
  OS1)
    local baseurl_file="file://$mountPatch"
    baseos
    ;;
  OS2)
    local baseurl_file="file://$mountPatch/BaseOS"
    baseos
    appstream
    ;;
  OS3)
    local baseurl_file="file://$mountPatch"
    baseos
    appstream
    ;;
  OS4)
    config=$(
      cat <<EOF
[openEuler]
name=openEuler
baseurl=file://$mountPatch
enabled=1
gpgcheck=1
gpgkey=file://$mountPatch/RPM-GPG-KEY-openEuler
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee -a "$repo_name"
    ;;
  esac
  # 清除旧的yum源，重建新的yum源
  if ! run_cmd yum clean all >/dev/null 2>&1; then
    color_printf red "清理 yum 缓存失败，请检查系统日志！"
    exit 1
  fi
  printf "\n"
  # 重新生成 yum 缓存
  if ! run_cmd yum makecache >/dev/null 2>&1; then
    color_printf red "当前镜像仓库配置错误，请自行检查软件源配置！"
    exit 1
  else
    color_printf green "镜像仓库配置成功！"
  fi
}
#==============================================================#
# 禁用防火墙
#==============================================================#
function conf_port_firewall() {
  # 输出一条日志消息表示正在禁用防火墙
  log_print "添加端口并禁用防火墙"
  # 根据不同的安装模式选择要开放的端口
  case $dm_install_mode in
  single)
    declare -a ports=("$port_num")
    ;;
  datawatch)
    declare -a ports=("$port_num" "$mal_port_num" "$mal_dw_port_num" "$mal_inst_dw_port_num")
    ;;
  dsc | dscm)
    declare -a ports=("$port_num" "$css_dcr_ep_port" "$asm_dcr_ep_port" "$db_dcr_ep_port" "$asvrmal_mal_port" "$db_mal_port")
    ;;
  esac
  # 如果操作系统版本为 RHEL 6
  if [[ $os_version -eq 6 ]]; then
    # 如果 iptables 服务正在运行
    if run_cmd service iptables status >/dev/null 2>&1; then
      # 遍历每个端口并将其添加到 iptables 规则
      for port in "${ports[@]}"; do
        run_cmd iptables -A INPUT -s 0.0.0.0/0.0.0.0 -p tcp --dport "$port" -j ACCEPT
        # 检查是否成功添加端口
        if [ $? -eq 0 ]; then
          printf "端口 %s 已成功添加到iptables规则。\n" "$port"
        else
          printf "添加端口 %s 到iptables规则失败。\n" "$port"
        fi
      done
      printf "\n"
      # 保存 iptables 规则
      run_cmd iptables-save >/etc/sysconfig/iptables
      run_cmd service iptables stop
    else
      printf "防火墙服务未启动，无需禁用！\n"
      return
    fi
    # 禁用 iptables 和 ip6tables 的开机自启
    run_cmd chkconfig iptables off
    run_cmd chkconfig ip6tables off
    # 查看 iptables 状态
    run_cmd service iptables status
  else
    # 如果操作系统版本不是 RHEL 6
    # 检查 firewalld 服务是否正在运行
    if [[ $(systemctl status firewalld.service | grep -c running) -gt 0 ]]; then
      # 遍历每个端口并将其添加到 firewalld 配置中
      for port in "${ports[@]}"; do
        run_cmd firewall-cmd -q --zone=public --add-port="$port/tcp" --permanent
        # 检查是否成功添加端口
        if [ $? -eq 0 ]; then
          printf "端口 %s 已成功添加到防火墙。\n" "$port"
        else
          printf "添加端口 %s 到防火墙失败。\n" "$port"
        fi
      done
      # 重新加载 firewalld 配置
      run_cmd firewall-cmd -q --reload
      # 停止 firewalld 服务
      run_cmd systemctl stop firewalld.service -q
    else
      echo "防火墙服务未启动，无需禁用！"
      return
    fi
    printf "\n"
    # 禁用 firewalld 的开机自启
    run_cmd systemctl disable firewalld.service -q
    # 查看 firewalld 状态
    run_cmd systemctl status firewalld -q
  fi
}
#==============================================================#
# 禁用 selinux
#==============================================================#
function conf_selinux() {
  # 输出一条日志消息表示正在禁用 SELinux，并备份 /etc/selinux/config 配置文件
  log_print "禁用 SELinux"
  local config_file="/etc/selinux/config"
  bak_file "$config_file"
  # 获取当前SELinux状态
  status=$(getenforce)
  # 判断SELinux状态
  case "$status" in
  "Disabled")
    # 如果 SELinux 已经禁用，则输出信息
    printf "SELinux 已经被禁用\n"
    ;;
  "Enforcing")
    # 如果 SELinux 正在强制执行，则禁用它并修改配置文件
    printf "SELinux 正在强制执行，现在将其设置为禁用\n"
    run_cmd setenforce 0
    run_cmd sed -i 's/SELINUX=.*/SELINUX=disabled/' "$config_file"
    printf "SELinux 已被设置为禁用，请重启系统以使更改生效\n"
    ;;
  *)
    # 如果 SELinux 是宽容模式，则禁用它并修改配置文件
    printf "SELinux 是宽容模式\n"
    run_cmd sed -i 's/SELINUX=.*/SELINUX=disabled/' "$config_file"
    printf "SELinux 已被设置为禁用，请重启系统以使更改生效\n"
    ;;
  esac
}
#==============================================================#
# 关闭 SWAP 功能
#==============================================================#
function conf_swap() {
  # 输出一条日志消息表示正在关闭 SWAP 功能
  log_print "调整 SWAP 分区"
  local fstab_file="/etc/fstab"
  # 获取系统中 SWAP 分区的大小并判断是否存在 SWAP 分区
  local -r swap=$(free | grep Swap | awk '{print $2}')
  # 如果没有发现 SWAP 分区
  if [[ -z $swap ]]; then
    color_printf yellow "系统中不存在 SWAP 分区，无需调整 SWAP 分区！"
  else
    # 如果物理内存大于 40 GB (41943040 KB)，则关闭 SWAP
    if [[ $os_memory -gt 41943040 ]]; then
      # 关闭所有 SWAP 分区
      run_cmd swapoff -a
      # 备份 /etc/fstab 文件
      bak_file "$fstab_file"
      # 注释掉 fstab 中与 SWAP 相关的行
      run_cmd sed -ri 's/.*swap.*/#&/' "$fstab_file"
    fi
    # 输出当前系统内存的使用情况并检查 /etc/fstab 文件中是否有包含 "swap" 的行
    free -m
    printf "\n"
    grep <"$fstab_file" -v "^$" | grep "swap"
  fi
}
#==============================================================#
# 禁用透明大页&禁用NUMA&开启I/0 schedule
#==============================================================#
function conf_grub() {
  # 添加注释和变量
  log_print "禁用透明大页 & 禁用 NUMA & 开启 I/O 调度"
  # 启动参数
  local transparent_hugepage="transparent_hugepage=never" # 禁用透明大页
  local elevator="elevator=deadline"                      # 使用 deadline I/O 调度算法
  local numa="numa=off"                                   # 禁用 NUMA
  # 更新启动参数的函数
  function update_parameter() {
    local parameter=$1
    # 检查启动参数是否已存在，不存在则添加
    if [[ $(run_cmd grubby --info=ALL | grep -c "$parameter") -eq 0 ]]; then
      # 更新所有内核的启动参数
      run_cmd grubby --update-kernel=ALL --args="$parameter"
    fi
  }
  # 启动参数列表
  local options=("${transparent_hugepage}" "${elevator}" "${numa}")
  # 更新每个启动参数
  for option in "${options[@]}"; do
    update_parameter "$option"
  done
  # 输出更新后的启动参数信息
  run_cmd grubby --info=ALL | awk '/numa/{print $0 "\n-" $(NR-1) "\n-" $(NR-2)}'
}
#==============================================================#
# 创建dmdba操作系统用户
#==============================================================#
function create_os_user() {
  # 初始化日志和变量
  log_print "开始创建 dmdba 用户，密码为：$dm_passwd"
  local dinstall_group="dinstall"   # 安装组
  local dmdba_group="dmdba"         # dmdba 组
  local dmsso_group="dmsso"         # dmsso 组
  local dmauditor_group="dmauditor" # 审计组
  local dmdba_id=56781              # dmdba 用户 ID
  local dmdba_user="dmdba"          # dmdba 用户名
  # 创建用户组的函数
  function create_group() {
    local group=$1    # 组名
    local group_id=$2 # 组ID
    # 组ID冲突时增加1234
    while grep -q ":$group_id:" /etc/group; do
      group_id=$((group_id + 1234))
    done
    # 判断组名是否已存在
    if ! grep -q "^$group:" /etc/group; then
      # 创建组
      run_cmd /usr/sbin/groupadd -g "$group_id" "$group"
    fi
  }
  # 创建或修改用户的函数
  function create_user() {
    local user=$1 # 用户名
    local base_cmd=""
    # 检查用户 ID 冲突
    while grep -q ":$dmdba_id:" /etc/passwd; do
      dmdba_id=$((dmdba_id + 1234))
    done
    # 检查用户是否存在
    if ! grep -q "^$user:" /etc/passwd; then
      # 用户不存在，构建 useradd 命令
      base_cmd="/usr/sbin/useradd -u $dmdba_id -g $dinstall_group"
    else
      # 用户已存在，构建 usermod 命令
      base_cmd="/usr/sbin/usermod -g $dinstall_group"
    fi
    # 根据 os_auth 添加附加组
    if [[ $os_auth =~ [Yy] ]]; then
      base_cmd="$base_cmd -G $dmdba_group,$dmsso_group,$dmauditor_group"
    fi
    # 添加通用参数
    base_cmd="$base_cmd -s /bin/bash -d /home/$user -m $user"
    # 执行命令
    eval "$base_cmd" >/dev/null 2>&1
  }
  # 创建必要的用户组
  create_group $dinstall_group 56781
  if [[ $os_auth =~ [Yy] ]]; then
    create_group $dmdba_group 56782
    create_group $dmsso_group 56783
    create_group $dmauditor_group 56784
  fi
  # 创建或修改 dmdba 用户
  create_user $dmdba_user
  # 设置 dmdba 用户密码
  echo "$dmdba_user:$dm_passwd" | run_cmd /usr/sbin/chpasswd
  # 显示用户信息
  grep </etc/passwd $dmdba_user
  printf "\n"
  id $dmdba_user
  # 如果只创建用户而不配置 sudo 权限
  if [[ $only_create_user =~ [Yy] ]]; then
    # 配置 dmdba 用户的 sudo 权限
    local sudoers_file=/etc/sudoers.d/dmdba
    params=(
      "# DMBegin"
      "dmdba ALL=(ALL) NOPASSWD: ALL" # 允许 dmdba 用户执行所有命令而无需密码
    )
    run_cmd printf "%s\n" "${params[@]}" | run_cmd tee "$sudoers_file" >/dev/null
    chmod 0440 "$sudoers_file" # 修改 sudoers 文件权限
    # 显示成功消息
    printf "\n"
    printf "%s用户密码是：%s\n" "$dmdba_user" "$(color_printf green "$dm_passwd")"
    printf "\n"
  fi
}
#==============================================================#
# 配置内核参数和资源
#==============================================================#
function conf_sysctl() {
  log_print "配置内核参数和资源"
  local sysctl_file="/etc/sysctl.conf"
  # 获取系统页面大小，用于计算内存总量
  pagesize=$(getconf PAGE_SIZE) || true
  # 计算内存总量（以 KB 或字节为单位）
  shmall=$(((os_memory - 10) * 1024 / pagesize)) || true
  shmmax=$((os_memory * 1024 - 10)) || true
  ((shmall < 2097152)) && shmall=2097152       # 最小 4GB-1
  ((shmmax < 4294967295)) && shmmax=4294967295 # 最小 8GB（4KB页）
  # 备份文件
  bak_file "$sysctl_file"
  # 修改 /etc/sysctl.conf 文件，添加内核和资源配置
  params=(
    "# DMBegin"
    "fs.aio-max-nr = 1048576"                                                      # 最大异步 I/O 事件数
    "fs.file-max = 6815744"                                                        # 系统可分配的最大文件句柄数
    "fs.nr_open = 20480000"                                                        # 系统范围内可打开的最大文件数
    "kernel.core_pattern = $core_dir/core.%e.%p.%t"                                # Core dump 文件名模式
    "kernel.panic_on_oops = 1"                                                     # Oops（内核恐慌）时内核行为
    "kernel.numa_balancing = 0"                                                    # 出于性能考虑禁用 NUMA 平衡
    "kernel.randomize_va_space = 2"                                                # 地址空间布局随机化（ASLR）安全特性
    "kernel.shmall = $shmall"                                                      # 系统范围内共享内存的最大总量
    "kernel.shmmax = $shmmax"                                                      # 单个共享内存段的最大大小
    "kernel.shmmni = 4096"                                                         # 可创建的最大共享内存段数
    "kernel.sem = 250 32000 100 128"                                               # 信号量调整参数：semmsl、semmns、semopm 和 semmni
    "net.ipv4.ip_local_port_range = 9000 65500"                                    # 出站连接的本地端口范围
    "net.ipv4.tcp_retries2 = 3"                                                    # TIME-WAIT 状态下 TCP 段的最大重试次数
    "net.ipv4.tcp_fin_timeout = 5"                                                 # TCP 最终数据包的超时时间
    "net.ipv4.tcp_synack_retries = 2"                                              # 被动 TCP 连接的 SYNACK 数据包的重试次数
    "net.ipv4.tcp_syncookies = 1"                                                  # 启用 TCP SYN cookies 以防止 SYN 洪水攻击
    "net.ipv4.tcp_timestamps = 1"                                                  # 启用 TCP 时间戳以进行更好的往返时间测量
    "net.ipv4.tcp_rmem = 8192 87380 16777216"                                      # TCP 接收缓冲区内存分配
    "net.ipv4.tcp_wmem = 8192 65536 16777216"                                      # TCP 发送缓冲区内存分配
    "net.core.rmem_default = 262144"                                               # 所有网络接口接收缓冲区大小的默认值
    "net.core.rmem_max = 4194304"                                                  # 所有网络接口接收缓冲区大小的最大值
    "net.core.wmem_default = 262144"                                               # 所有网络接口发送缓冲区大小的默认值
    "net.core.wmem_max = 1048576"                                                  # 所有网络接口发送缓冲区大小的最大值
    "vm.swappiness = 10"                                                           # 控制内核倾向于交换匿名内存的程度
    "vm.min_free_kbytes = $(free -k | awk 'NR==2 {printf "%d\n", int($2 / 200)}')" # 触发交换所需的最小空闲内核内存量
    "vm.numa_stat = 0"                                                             # 报告 NUMA 内存本地性统计
    "vm.overcommit_memory = 0"                                                     # 启用内存过度承诺
    "vm.zone_reclaim_mode = 0"                                                     # 控制内存区域的内存回收行为
    "# DMEnd"
  )
  # 将内核配置写入文件并应用
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$sysctl_file" >/dev/null
  # 重新加载内核配置
  run_cmd sysctl -p
}
#==============================================================#
# 配置系统资源
#==============================================================#
function conf_limits() {
  log_print "配置系统资源"
  local limits_file="/etc/security/limits.conf"
  # 备份文件
  bak_file "$limits_file"
  # 修改/etc/security/limits.conf文件
  params=(
    "# DMBegin"
    # 设置核心转储文件大小限制为0
    "*     hard core 0"
    "*     soft core 0"
    "dmdba soft core unlimited"
    "dmdba hard core unlimited"
    # 设置进程数限制为10240
    "dmdba soft nproc 10240"
    "dmdba hard nproc 10240"
    # 设置文件描述符限制为65536
    "dmdba soft nofile 65536"
    "dmdba hard nofile 65536"
    # 设置数据段大小限制为无限制
    "dmdba hard data unlimited"
    "dmdba soft data unlimited"
    # 设置文件大小限制为无限制
    "dmdba hard fsize unlimited"
    "dmdba soft fsize unlimited"
    # 设置堆栈大小限制为65536
    "dmdba soft stack  65536"
    "dmdba hard stack  65536"
    "# DMEnd"
  )
  # 将设置内容追加到配置文件
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$limits_file" >/dev/null
  # 输出修改后的部分内容
  sed -n '/# DMBegin/,/# DMEnd/p' "$limits_file" | grep -v '^#|^*#|^$'
  printf "\n"
  # 修改 /etc/pam.d/login 文件以确保 PAM 加载 limits.conf 配置
  local login_file="/etc/pam.d/login"
  local login_file="/etc/pam.d/login"
  bak_file "$login_file"
  params=(
    "# DMBegin"
    "session required pam_limits.so"
    "session required /lib64/security/pam_limits.so"
    "# DMEnd"
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$login_file" >/dev/null
  sed -n '/# DMBegin/,/# DMEnd/p' "$login_file" | grep -v '^#|^*#|^$'
}
#==============================================================#
# 配置文件数和进程数
#==============================================================#
function conf_system_nproc() {
  log_print "配置文件数和进程数限制"
  local systemd_file="/etc/systemd/system.conf"
  # 在CentOS7 / RHEL7系统中使用Systemd替代了之前的SysV，需要修改/etc/systemd/system.conf文件。
  if [[ $os_version -ne 6 ]]; then
    # 备份文件
    bak_file "$systemd_file"
    # 修改/etc/systemd/system.conf文件
    params=(
      "# DMBegin"
      "DefaultLimitCORE=infinity"
      "DefaultLimitNOFILE=65536"
      "DefaultLimitNPROC=10240"
      "#DMEnd"
    )
    run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$systemd_file" >/dev/null
    sed -n '/DefaultLimit/p' "$systemd_file" | grep -v '^#'
    printf "\n"
  fi
  # 创建/etc/security/limits.d/dm-nproc.conf文件
  local nproc_file="/etc/security/limits.d/dm_nproc.conf"
  if check_file "$nproc_file"; then
    bak_file "$nproc_file"
    cat "$nproc_file"
  else
    params=(
      "# DMBegin"
      "dmdba soft nproc 65536"
      "dmdba hard nproc 65536"
      "# DMEnd"
    )
    run_cmd printf "%s\n" "${params[@]}" | run_cmd tee "$nproc_file" >/dev/null
    sed -n '/# DMBegin/,/# DMEnd/p' "$nproc_file" | grep -v '^#|^*#|^$'
  fi
}
#==============================================================#
# 配置与用户会话和系统登录管理相关的参数
#==============================================================#
function conf_logind() {
  local logind_file="/etc/systemd/logind.conf"
  # 如果操作系统是linux6，则无需配置此服务
  if [[ $os_version -eq 6 ]]; then
    return 1
  fi
  log_print "配置与用户会话和系统登录管理相关的参数"
  # 检查文件是否存在
  if ! check_file "$logind_file"; then
    color_printf red "${logind_file}文件不存在，无法进行修改操作。"
    return 1
  fi
  # 避免注销用户时意外结束数据库进程
  current_value=$(loginctl show-session -p KillUserProcesses | cut -d= -f2 | tr -d '[:space:]')
  if [[ "$current_value" == "yes" ]]; then
    # 注释掉 KillUserProcesses 行
    run_cmd sed -i '/^KillUserProcesses/Is/^/#/' "$logind_file"
  fi
  # 备份文件
  bak_file "$logind_file"
  # 修改文件
  params=(
    "# DMBegin"
    "HandleSuspendKey=ignore"   # 避免系统进入挂起状态
    "HandleHibernateKey=ignore" # 避免系统进入休眠状态
    "IdleAction=ignore"         # 确保数据库服务器不会因空闲而执行节能操作
    "KillUserProcesses=no"      # 避免注销用户时意外结束数据库进程
    "RemoveIPC=no"              # 确保数据库服务不受IPC资源清理的影响
    "# DMEnd"
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$logind_file" >/dev/null
  # 重新加载daemon和重启systemd-logind服务
  run_cmd systemctl daemon-reload -q
  run_cmd systemctl restart systemd-logind -q
  # 显示修改后的文件内容
  sed -n '/# DMBegin/,/# DMEnd/p' "$logind_file" | grep -v '^#|^*#|^$'
}
#==============================================================#
# 配置主机名
#==============================================================#
function conf_hostname() {
  log_print "配置主机名"
  local network_file="/etc/sysconfig/network"
  local current_hostname host_name
  # 获取当前主机名
  current_hostname=$(hostname)
  # 计算目标主机名
  if [[ $dm_install_mode == "single" ]]; then
    host_name="$hostname"
  else
    host_name=$( ((node_num == -1)) && echo "dwmon" || echo "${hostname}$(printf "%02d" "$node_num")")
  fi
  # 如果目标主机名为空或者与当前主机名相同，则不需要修改
  if [[ -z "$hostname" || "$current_hostname" == "$host_name" ]]; then
    printf "当前主机名：%s，无需修改。\n" "$current_hostname"
    return 0
  fi
  # 判断操作系统版本
  if [[ $os_version -eq 6 ]]; then
    # 备份配置文件
    bak_file "${network_file}"
    # 修改主机名
    run_cmd /bin/hostname "$host_name"
    run_cmd sysctl kernel.hostname="$host_name"
    run_cmd printf "%s" "$host_name" | run_cmd tee /proc/sys/kernel/hostname >/dev/null
    # 更新 network 配置文件中的主机名
    run_cmd sed -i "s/HOSTNAME=$current_hostname/HOSTNAME=$host_name/" "${network_file}"
    # 输出修改后的主机名
    printf "当前主机名：%s\n" "$(grep -E 'HOSTNAME=' "${network_file}" | cut -d= -f2)"
  else
    # 对于其他操作系统，使用 hostnamectl 修改主机名
    bak_file "/etc/hostname"
    run_cmd hostnamectl set-hostname "$host_name"
    # 输出修改后的主机名
    printf "当前主机名：%s\n" "$(hostnamectl --static)"
  fi
}
#==============================================================#
# 配置 hosts 信息
#==============================================================#
function conf_hosts() {
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ && $alias_replaces_ip =~ [Yy] ]]; then
    log_print "配置hosts文件"
    local hosts_file="/etc/hosts"
    local host_alias
    # 备份hosts文件
    bak_file "$hosts_file"
    # 判断hosts文件的权限
    [[ $(stat -c "%a" $hosts_file) != "644" ]] && chmod 644 $hosts_file
    # 开始添加别名
    run_cmd printf "%s\n" "# DMBegin" | run_cmd tee -a "$hosts_file"
    # 写入 /etc/hosts 文件并更新关联数组
    for ((x = 0; x < ${#all_malip_arr[@]}; x++)); do
      ip="${all_malip_arr[$x]}"
      # 生成实例名
      host_alias="$(upper "${dsc_ep_name}")$(printf "%02d" $((x + 1)))"
      # 将 IP 和主机名写入 /etc/hosts
      run_cmd printf "%s %s\n" "$ip" "$host_alias" | run_cmd tee -a "$hosts_file"
      # 将 host_alias 存入数组
      malip_host_arr+=("$host_alias")
    done
    # 查看新增的hosts信息
    grep -v "^\s*\(#\|$\)" "$hosts_file"
  else
    malip_host_arr=("${all_malip_arr[@]}")
  fi
}
#==============================================================#
# 配置 ntp timeserver
#==============================================================#
function conf_ntp() {
  local crontab_file="/var/spool/cron/root"
  local script_file="/usr/sbin/ntpdate"
  local ntp_file="/etc/ntp.conf"
  local ntpd_file="/etc/sysconfig/ntpd"
  local chrony_file="/etc/chrony.conf"
  local config
  case $os_version in
  6 | 7)
    # 备份 ntp 配置文件和 sysconfig 配置文件
    bak_file "$ntp_file"
    bak_file /etc/sysconfig/ntpd
    # 删除 ntp 配置文件中已有的时间服务器信息，并添加新的时间服务器信息
    run_cmd sed -i -e '/^server/d' -e '/^pool/d' "$ntp_file"
    # 使用 Here Document 来生成 ntp 配置内容
    config=$(
      cat <<EOF

tos maxdist 30
tinker panic 0
server $timeserver_ip iburst
server 127.127.1.0
fudge 127.127.1.0 stratum 8
notrust
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee -a "$ntp_file" >/dev/null
    # 创建 ntpd 进程ID文件
    run_cmd touch /var/run/ntpd.pid
    # 编辑 sysconfig 文件来配置 ntpd 服务
    config=$(
      cat <<EOF

OPTIONS="-g -x -p /var/run/ntpd.pid"
SYNC_HWCLOCK=yes
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee -a "$ntpd_file" >/dev/null
    # 配置定时任务
    if ! crontab -l -u root | grep -q "$script_file"; then
      run_cmd printf "# DMBegin\n" | run_cmd tee -a "$crontab_file" >/dev/null
      run_cmd printf "10 5 * * * root %s -u %s >/dev/null 2>&1 ; hwclock -w\n" "$script_file" "$timeserver_ip" | run_cmd tee -a "$crontab_file" >/dev/null
    fi
    ;;
  *)
    # 备份 chrony 配置文件
    bak_file /etc/chrony.conf
    run_cmd sed -i -e '/^server/d' -e '/^pool/d' /etc/chrony.conf
    # 使用 Here Document 来生成 chrony 配置内容
    config=$(
      cat <<EOF

server $timeserver_ip iburst
allow $(ip route | grep "$(hostname -I)" | awk '{print $1}')
local stratum 10
EOF
    )
    run_cmd printf "%s\n" "$config" | run_cmd tee -a "$chrony_file" >/dev/null
    # 配置定时任务
    if ! run_cmd crontab -u dmdba -l | grep -q "$script_file"; then
      run_cmd printf "# DMBegin\n" | run_cmd tee -a "$crontab_file" >/dev/null
      run_cmd printf "10 5 * * * root %s -u %s >/dev/null 2>&1 ; hwclock -w\n" "$script_file" "$timeserver_ip" | run_cmd tee -a "$crontab_file" >/dev/null
    fi
    ;;
  esac
}
#==============================================================#
# 配置时间同步
#==============================================================#
function conf_timesync() {
  # 如果时间服务器为空，退出函数
  if [[ -z $timeserver_ip ]]; then
    return 1
  fi
  log_print "配置时间同步服务"
  # 检查 ntpq 是否可用
  if ! command -v ntpq >/dev/null 2>&1; then
    packages=(
      ntp    # 网络时间协议服务器同步时间
      chrony # Linux 系统上提供时钟同步
    )
    # 安装 ntp 或 chrony
    install_package "${packages[@]}"
  fi
  # 如果存在时间服务器 IP，则配置 NTP/chrony 服务
  case $os_version in
  6)
    # 启动和开机启动 ntpd 服务
    run_cmd service ntpd start
    run_cmd chkconfig ntpd on
    # 配置 ntp
    conf_ntp
    # 手动同步一次服务器时间
    run_cmd /usr/sbin/ntpdate -u "$timeserver_ip" >/dev/null 2>&1
    # 重启 ntpd 服务，并检查其状态及时间同步情况
    run_cmd service ntpd restart
    # 记录时间同步后的日期和时间
    run_cmd ntpstat
    printf "\n"
    run_cmd ntpq -p -n
    ;;
  7)
    # 关闭并禁用 chrony 服务，备份 chrony 配置文件
    if systemctl is-active --quiet chronyd.service; then
      run_cmd systemctl stop chronyd.service
      run_cmd systemctl disable chronyd.service
      run_cmd mv /etc/chrony.conf /etc/chrony.conf.bak
    fi
    # 启动和开机启动 ntpd 服务
    run_cmd systemctl start ntpd.service
    run_cmd systemctl enable ntpd.service
    # 配置 ntp
    conf_ntp
    # 手动同步一次服务器时间
    run_cmd /usr/sbin/ntpdate -u "$timeserver_ip" >/dev/null 2>&1
    # 重启 ntpd 服务，并检查其状态及时间同步情况
    run_cmd systemctl restart ntpd.service
    # 记录时间同步后的日期和时间
    run_cmd ntpstat
    printf "\n"
    run_cmd ntpq -p -n
    ;;
  *)
    # 关闭并禁用 ntpd 服务，备份 ntpd 配置文件
    if systemctl is-active --quiet ntpd.service; then
      run_cmd systemctl stop ntpd.service
      run_cmd systemctl disable ntpd.service
      run_cmd mv /etc/ntpd.conf /etc/ntpd.conf.bak
    fi
    # 启动和开机启动 chronyd 服务
    run_cmd systemctl start chronyd.service
    run_cmd systemctl enable chronyd.service
    # 配置 ntp
    conf_ntp
    # 手动同步一次服务器时间
    /usr/sbin/ntpdate -u "$timeserver_ip" >/dev/null 2>&1
    # 重启 chrony 服务，并检查其状态及时间同步情况
    run_cmd systemctl restart chronyd.service
    run_cmd chronyc tracking
    printf "\n"
    run_cmd chronyc sources -v
    ;;
  esac
}
#==============================================================#
# 配置drop_cache脚本
#==============================================================#
function conf_drop_cache() {
  # 配置缓存清除脚本，使用cron job在指定时间清除缓存
  log_print "配置cache脚本" # 打印日志，记录函数执行进度
  local crontab_file="/var/spool/cron/root"
  local script_file="/root/drop_cache.sh"
  # 备份现有的crontab文件
  bak_file "$crontab_file"
  # 创建缓存清除脚本
  params=(
    "#!/bin/bash"
    "# DMBegin"
    "sync"
    "echo 1 > /proc/sys/vm/drop_caches"
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee "$script_file" >/dev/null
  run_cmd chmod 775 "$script_file"
  # 添加cron job到crontab文件
  if ! run_cmd crontab -l -u root | run_cmd grep -q "$script_file" >/dev/null 2>&1; then
    run_cmd printf "* 6 * * * root %s\n" "$script_file" | run_cmd tee -a "$crontab_file" >/dev/null
  fi
  # 打印缓存清除脚本和当前的crontab配置
  run_cmd cat "$script_file" && run_cmd crontab -l -u root
}
#==============================================================#
# 配置profile
#==============================================================#
function conf_profile() {
  log_print "配置/etc/profile"
  local locale_file="/etc/locale.conf"
  # 配置操作系统支持的所有字符集
  # 定义一个函数，用于备份和更新 locale 设置
  function update_locale() {
    local locale_file="$1" # 配置文件路径
    local lang_value="$2"  # 需要设置的语言环境（如 zh_CN.utf8 或 en_US.utf8）
    # 备份配置文件
    bak_file "$locale_file"
    params=(
      "# DMBegin"
      "LANG=$lang_value"     # 设置 LANG 环境变量
      "LC_CTYPE=$lang_value" # 设置 LC_CTYPE 环境变量
    )
    # 将设置内容追加到配置文件
    run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$locale_file" >/dev/null
    # 检查是否成功添加语言环境设置
    grep <"${locale_file}" "zh_CN.utf8|en_US.utf8"
  }
  # 主逻辑部分
  if [[ $os_version -ne 6 ]]; then # 如果操作系统版本不是6
    # 检查是否安装了 zh_CN.utf8 locale
    if run_cmd locale -a | grep -qw "zh_CN.utf8"; then
      # 如果有 zh_CN.utf8，调用 update_locale 函数更新配置文件
      update_locale "$locale_file" "zh_CN.utf8"
    else
      # 如果没有 zh_CN.utf8，使用默认的 en_US.utf8 设置
      update_locale "$locale_file" "en_US.utf8"
    fi
  fi
  # 修改文件
  # 导入语言
  local profile_file="/etc/profile"
  bak_file "${profile_file}"
  if locale -a | grep -q "zh_CN.utf8"; then
    params=(
      "# DMBegin"
      "export LANG=zh_CN.UTF-8" # 设置 LANG 环境变量
      "# DMEnd"
    )
  else
    params=(
      "# DMBegin"
      "export LANG=en_US.UTF-8" # 设置 LANG 环境变量
      "# DMEnd"
    )
  fi
  # 将设置内容追加到配置文件
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$profile_file" >/dev/null
  awk '/export LANG/{print}' "$profile_file" | grep -v '^#|^*#|^$'
  printf "\n"
  # 内存池管理调整
  params=(
    "# DMBegin"
    "export MALLOC_ARENA_MAX=4"
    "# DMEnd"
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$profile_file" >/dev/null
  # shellcheck source=/dev/null
  run_cmd bash -c "source /etc/profile"
  awk '/export MALLOC_ARENA_MAX/{print}' "$profile_file" | grep -v '^#|^*#|^$'
}
#==============================================================#
# 配置用户环境变量
#==============================================================#
function conf_user_profile() {
  log_print "配置用户环境变量"
  color_printf blue "配置root环境变量"
  printf "\n"
  # 数据库实例路径
  local data_path=
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
    data_path="$data_dir"/"$dsc_db_name"
  else
    data_path="$data_dir"/"$db_name"
  fi
  # 更新 root 用户的 bash 配置文件
  local bash_profile_file="/root/.bash_profile"
  bak_file "$bash_profile_file"
  params=(
    "# DMBegin"
    "alias sd='su - dmdba'"
    "export PS1=\"[\`whoami\`@\`hostname\`:\"'\$PWD]# '"
    "# DMEnd"
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$bash_profile_file" >/dev/null
  run_cmd grep -E -v '^#|^$' $bash_profile_file
  printf "\n"
  color_printf blue "配置dmdba环境变量"
  printf "\n"
  # 更新 dmdba 用户的 bash 配置文件
  local bash_profile_file="/home/dmdba/.bash_profile"
  bak_file "$bash_profile_file"
  params=(
    "# DMBegin"
    "export LD_LIBRARY_PATH=\"/usr/lib64:\$LD_LIBRARY_PATH:$env_dm_home/bin\""
    "export DM_HOME=\"$env_dm_home\""
    "export JAVA_HOME=\"\${DM_HOME}/jdk\""
    "export JRE_HOME=\"\${JAVA_HOME}/jre\""
    "export CLASSPATH=\"\${JAVA_HOME}/lib:\${JRE_HOME}/lib:\$CLASSPATH\""
    "export PATH=\"\$PATH:\$JAVA_HOME/bin:\$JRE_HOME/bin:\$DM_HOME/bin:\$DM_HOME/tool\""
    "export PS1=\"[\`whoami\`@\`hostname\`:\"'\$PWD]$ '"
    "alias dmbin=\"cd \$DM_HOME/bin\""
    "alias dmlog=\"cd \$DM_HOME/log\""
    "alias dmdata=\"cd $data_path\""
  )
  run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$bash_profile_file" >/dev/null
  # 如果是操作系统认证，配置免密登录
  if [[ $os_auth =~ [Yy] ]]; then
    params=(
      "alias ds=\"disql -L /:$port_num as sysdba\""
      "alias dsql=\"disql -L -S /:$port_num as sysdba -C \\\"set linesize 999 pagesize 999 long 1000 feed off\\\" -E\""
      "alias dssql=\"disql -L -S /:$port_num as sysdba \\\\\\\`\""
    )
    run_cmd printf "%s\n" "${params[@]}" | run_cmd tee -a "$bash_profile_file" >/dev/null
  fi
  # 根据数据库架构，添加补充别名信息
  case $dm_install_mode in
  "single")
    run_cmd printf 'alias sqllog="cd %s/%s/sqllog"\n' "$backup_dir" "$db_name" | run_cmd tee -a "$bash_profile_file" >/dev/null
    ;;
  "datawatch")
    run_cmd printf 'alias sqllog="cd %s/%s/sqllog"\n' "$backup_dir" "$db_name" | run_cmd tee -a "$bash_profile_file" >/dev/null
    run_cmd printf 'alias dm="dmmonitor %s/dmmonitor_%s.ini"\n' "$data_path" "$dw_group_name" | run_cmd tee -a "$bash_profile_file" >/dev/null
    ;;
  "dsc" | "dscm")
    run_cmd printf 'alias sqllog="cd %s/%s/sqllog"\n' "$data_path" "$(lower "$dsc_ep_name")$(printf "%02d" "$node_num")_config" | run_cmd tee -a "$bash_profile_file" >/dev/null
    run_cmd printf 'alias dc="dmcssm %s/dmcssm.ini"\n' "$data_path" | run_cmd tee -a "$bash_profile_file" >/dev/null
    ;;
  esac
  run_cmd printf "%s\n" "# DMEnd" | run_cmd tee -a "$bash_profile_file" >/dev/null
  # 输出更新后的 dmdba 用户的 bash 配置文件内容
  run_cmd grep -E -v '^#|^$' $bash_profile_file
}
#==============================================================#
# 创建安装目录
#==============================================================#
function create_env_dir() {
  if [[ $only_init_db =~ [Yy] ]]; then
    # 检查是否有数据库相关进程在运行
    if pgrep -f "dmimon|dmap|dmserver|dmwatcher|dmmonitor|dmcss|dmcssm|dmasmsvr|dmasmsvrm" >/dev/null 2>&1; then
      # 数据库相关进程正在运行，尝试获取 env_dm_home 路径
      if [[ "$os_version" -ne 6 ]]; then
        # 获取路径
        env_dm_home=$(pgrep -af "dmimon|dmap|dmserver|dmwatcher|dmmonitor|dmcss|dmcssm|dmasmsvr|dmasmsvrm" | awk '{print $2}' | xargs --no-run-if-empty dirname | sed 's|/bin.*$||' | head -1)
      else
        # shellcheck disable=SC2009
        env_dm_home=$(ps -ef | grep -E "dmimon|dmap|dmserver|dmwatcher|dmmonitor|dmcss|dmcssm|dmasmsvr|dmasmsvrm" | grep -v grep | awk '{split($8, a, "/bin"); print a[1]}' | head -1)
      fi
      if [[ -z "$env_dm_home" ]]; then
        color_printf red "错误：无法获取 env_dm_home 路径"
        exit 1
      fi
    else
      # 没有相关进程，创建新的 env_dm_home 目录
      run_cmd mkdir -m 755 -p "$env_dm_home"
      run_cmd chown dmdba:dinstall "$env_dm_home"
    fi
  else
    # 非初始化模式，先检查是否有数据库进程运行
    if pgrep -f "dmimon|dmserver|dmwatcher|dmmonitor|dmcss|dmcssm|dmasmsvr|dmasmsvrm" >/dev/null 2>&1; then
      pgrep -f "dmimon|dmserver|dmwatcher|dmmonitor|dmcss|dmcssm|dmasmsvr|dmasmsvrm" | run_cmd xargs --no-run-if-empty kill -9
      wait
    fi
    # 判断目录是否存在，并且非空
    if [[ -d "$env_dm_home" && "$(ls -A "$env_dm_home")" ]]; then
      run_cmd mv "$env_dm_home" "${env_dm_home}${current}"
    fi
    # 创建新的 env_dm_home 目录
    run_cmd mkdir -m 755 -p "$env_dm_home"
    run_cmd chown dmdba:dinstall "$env_dm_home"
  fi
}
#==============================================================#
# 挂载达梦安装镜像
#==============================================================#
function mount_iso() {
  log_print "挂载 DM ISO 文件"
  # 卸载已经挂载的 dmiso 数据库镜像
  mount_output=$(run_cmd mount)
  while IFS= read -r line; do
    if [[ "$line" =~ dm8|dm9 ]]; then
      # 提取设备名并执行卸载操作
      device=$(echo "$line" | awk '{print $(NF-3)}')
      run_cmd umount -f "$device"
    fi
  done <<<"$mount_output"
  # 清理空目录
  run_cmd find "${software_dir}" -type d -empty -delete 2>&1
  # 创建挂载目录
  mount_dir="${software_dir}/${random_string}"
  if [ ! -d "$mount_dir" ]; then
    run_cmd mkdir -p "$mount_dir"
  fi
  # 卸载 /run/media/root/dameng 目录（如果挂载过）
  if [ -d /run/media/root/dameng ]; then
    run_cmd umount -f /run/media/root/dameng
  fi
  run_cmd mount -t auto -o ro,loop "${software_dir}/$dm_iso_name" "$mount_dir"
  # 列出挂载目录内容
  ls -lrth "$mount_dir"
  # 清理工作
  function cleanup() {
    # shellcheck disable=SC2317
    run_cmd umount -f "$mount_dir" >/dev/null 2>&1
    # shellcheck disable=SC2317
    run_cmd find "${software_dir}" -type d -empty -delete 2>&1
  }
  # 在脚本退出时执行清理
  if [[ -n "$dm_iso_name" ]]; then
    trap cleanup EXIT
  fi
}
#==============================================================#
# 安装达梦数据库软件
#==============================================================#
function install_dmdb() {
  # 如果仅初始数据库实例
  if [[ $only_init_db =~ [Yy] ]]; then
    # 检查数据库是否已经安装
    if run_cmd su - dmdba -c "$env_dm_home/bin/disql -id" >/dev/null 2>&1; then
      log_print "达梦数据库软件已经安装"
      run_cmd su - dmdba -c "$env_dm_home/bin/disql -id"
      # 判断数据库是不是安全版
      if run_cmd su - dmdba -c "$env_dm_home/bin/dminit help" 2>/dev/null | grep -qP "SYSSSO_PWD(?!=[.])"; then
        db_flag=true
      fi
      # 删除临时目录
      if [ -n "$dm_iso_name" ] || check_file "$software_dir/$random_string/DMInstall.bin"; then
        run_cmd umount -f "${software_dir}/${random_string}" >/dev/null 2>&1
        run_cmd find "${software_dir}" -type d -empty -delete 2>&1
      fi
      return
    fi
    # 数据库未安装，准备进行安装
    log_print "开始安装达梦数据库软件"
  else
    log_print "开始安装达梦数据库软件"
  fi
  local dm_svc_file="/etc/dm_svc.conf"
  local config
  # 如果存在，备份文件
  bak_file "$dm_svc_file"
  # 生成安装配置文件 auto_install.xml
  local lang="zh"
  if [[ $LANG == "en_US.UTF-8" ]]; then
    lang="en"
  fi
  # 生成 XML 配置
  config=$(
    cat <<EOF
<?xml version="1.0"?>
<DATABASE>
    <LANGUAGE>$lang</LANGUAGE>
    <TIME_ZONE>+08:00</TIME_ZONE>
    <KEY>$key_path</KEY>
    <INSTALL_TYPE>0</INSTALL_TYPE>
    <INSTALL_PATH>$env_dm_home</INSTALL_PATH>
    <INIT_DB>N</INIT_DB>
</DATABASE>
EOF
  )
  # 使用 printf 和 run_cmd tee 写入 XML 配置文件
  run_cmd printf "%s\n" "$config" | tee "${software_dir}/auto_install.xml" >/dev/null
  # 安装数据库
  function install_dmsoft() {
    local install_bin="$1"
    local install_xml="$2"
    # 执行安装命令
    run_cmd chmod -f +x "$install_bin"
    run_cmd sh -c "export DM_INSTALL_TMPDIR=\"$software_dir\"; ulimit -n 65536; \"$install_bin\" -q \"$install_xml\" 2>&1"
    # 安装失败时恢复配置文件并退出
    if [ $? -ne 0 ]; then
      color_printf red "达梦数据库软件安装失败"
      if check_file "${dm_svc_file}".original; then
        run_cmd cp -pf "${dm_svc_file}".original "$dm_svc_file"
      fi
      exit 1
    fi
  }
  # 使用不同的软件安装数据库
  if [ -n "$dm_iso_name" ] && check_file "$software_dir/$random_string/DMInstall.bin"; then
    install_dmsoft "${software_dir}/${random_string}/DMInstall.bin" "${software_dir}/auto_install.xml"
    # 安装成功之后卸载挂载的DMISO镜像
    run_cmd umount -f "${software_dir}/${random_string}" >/dev/null 2>&1
    run_cmd find "${software_dir}" -type d -empty -delete 2>&1
  elif check_file "${software_dir}/DMInstall.bin"; then
    install_dmsoft "${software_dir}/DMInstall.bin" "${software_dir}/auto_install.xml"
  else
    color_printf red "找不到达梦数据库安装程序 DMInstall.bin"
    exit 1
  fi
  # 判断数据库是不是安全版
  if run_cmd su - dmdba -c "$env_dm_home/bin/dminit help" 2>/dev/null | grep -qP "SYSSSO_PWD(?!=[.])"; then
    db_flag=true
  fi
  # 分布式模式需要添加动态链接库软链接
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ && $os_version -eq 6 ]]; then
    if [[ $(find /lib64/* -maxdepth 1 -name "libdm*.so" | wc -l) -le 6 ]]; then
      run_cmd ln -sf "$env_dm_home"/bin/*.so /lib64
    fi
  fi
}
