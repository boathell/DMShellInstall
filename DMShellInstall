    FROM v\$dm_ini
    WHERE para_name = 'COMPATIBLE_MODE';
    -- 检查COMPATIBLE_MODE的值
    IF v_compatible_mode = 2 THEN
        -- 初始化命令数组
        v_commands := t_command_array(
