      echo "  1. systemctl stop DmWatcherService${dw_group_name}"
      echo "  2. systemctl stop DmService${db_name}"
    elif [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
      echo "【DSC集群服务】"
      echo "CSS服务:            DmCSSServiceCss"
      echo "  启动:             systemctl start DmCSSServiceCss"
      echo "  停止:             systemctl stop DmCSSServiceCss"
      echo "  重启:             systemctl restart DmCSSServiceCss"
      echo "  查看状态:         systemctl status DmCSSServiceCss"
      echo ""
      if [[ $dm_install_mode == "dsc" ]]; then
        echo "ASM服务:            DmASMSvrServiceAsmsvr"
        echo "  启动:             systemctl start DmASMSvrServiceAsmsvr"
        echo "  停止:             systemctl stop DmASMSvrServiceAsmsvr"
        echo "  重启:             systemctl restart DmASMSvrServiceAsmsvr"
        echo "  查看状态:         systemctl status DmASMSvrServiceAsmsvr"
      else
        echo "ASM服务:            DmASMSvrmServiceAsmsvr"
        echo "  启动:             systemctl start DmASMSvrmServiceAsmsvr"
        echo "  停止:             systemctl stop DmASMSvrmServiceAsmsvr"
        echo "  重启:             systemctl restart DmASMSvrmServiceAsmsvr"
        echo "  查看状态:         systemctl status DmASMSvrmServiceAsmsvr"
      fi
      echo ""
      echo "数据库服务:         DmService${dsc_db_name}"
      echo "  启动:             systemctl start DmService${dsc_db_name}"
      echo "  停止:             systemctl stop DmService${dsc_db_name}"
      echo "  重启:             systemctl restart DmService${dsc_db_name}"
      echo "  查看状态:         systemctl status DmService${dsc_db_name}"
      echo ""
      echo "【启动顺序】"
      echo "  1. systemctl start DmCSSServiceCss"
      if [[ $dm_install_mode == "dsc" ]]; then
        echo "  2. systemctl start DmASMSvrServiceAsmsvr"
      else
        echo "  2. systemctl start DmASMSvrmServiceAsmsvr"
      fi
      echo "  3. systemctl start DmService${dsc_db_name}"
      echo "【停止顺序】（相反）"
      echo "  1. systemctl stop DmService${dsc_db_name}"
      if [[ $dm_install_mode == "dsc" ]]; then
        echo "  2. systemctl stop DmASMSvrServiceAsmsvr"
      else
        echo "  2. systemctl stop DmASMSvrmServiceAsmsvr"
      fi
      echo "  3. systemctl stop DmCSSServiceCss"
    fi
    echo ""
    echo "--------------------------------------------------------------------------------"
    echo "七、常用运维命令"
    echo "--------------------------------------------------------------------------------"
    echo "切换dmdba用户:      su - dmdba"
    echo "连接数据库:         disql SYSDBA/'${sysdba_pwd_display}'@localhost:${port_num}"
    echo "查看数据库版本:     su - dmdba -c \"${env_dm_home}/bin/disql -id\""
    if [[ $dm_install_mode == "datawatch" ]]; then
      echo "启动数据守护监视器: dmmonitor ${data_dir}/${db_name}/dmmonitor_${dw_group_name}.ini"
    fi
    if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
      echo "启动CSSM管理工具:   dmcssm ${data_dir}/${dsc_db_name}/dmcssm.ini"
    fi
    echo ""
    echo "--------------------------------------------------------------------------------"
    echo "八、其他信息"
    echo "--------------------------------------------------------------------------------"
    echo "执行命令记录:       ${dminstalllog}"
    echo "报告文件位置:       ${report_file}"
    echo ""
    echo "================================================================================"
    echo "                              安装完成"
    echo "================================================================================"
  } | tee "$report_file"

  printf "\n"
  color_printf green "安装配置报告已生成: ${report_file}"
  color_printf yellow "⚠️  请妥善保管此报告文件，其中包含重要的密码信息！"
  printf "\n"
}
#==============================================================#
# 程序入口
#==============================================================#
main "$@" | tee -a "$dminstalllog"
