  local report_file="${software_dir}/dm_install_report_$(date +"%Y%m%d%H%M%S").txt"
  local install_time=$(date "+%Y-%m-%d %H:%M:%S")
  
  # 转换字符集为可读字符串
  local charset_str=""
  case $charset in
    0) charset_str="GB18030 (简体中文国家标准)" ;;
    1) charset_str="UTF-8 (Unicode字符集，推荐)" ;;
    2) charset_str="EUC-KR (韩文字符集)" ;;
