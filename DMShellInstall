#==============================================================#
# 选择数据库安装模式
#==============================================================#
function install_mode() {
  # 仅在一节点判断安装模式
  if [[ $node_num -ne 1 ]]; then
    return
  fi
  # 映射用户输入到部署类型
  declare -A mode_map=(
    [si]="single"
    [dw]="datawatch"
    [dsc]="dsc"
    [dscm]="dscm"
  )
  # 如果已经有部署类型，直接使用
  if [[ -z $dm_install_mode ]]; then
    while :; do
      printf "\n"
      read -rep "$(echo -e "\033[34m请选择达梦数据库部署类型：单机[si]/数据守护[dw]/dsc集群[dsc]/dsc集群(ASM镜像)[dscm]: \E[0m")" dm_install_mode
      printf "\n"
      # 检查输入是否有效，并赋值
      if [[ ${mode_map[$dm_install_mode]+exists} ]]; then
        dm_install_mode=${mode_map[$dm_install_mode]}
        color_printf green "达梦数据库安装部署类型: $dm_install_mode"
        break
      else
        color_printf red "无效输入！请选择 si、dw、dsc 或 dscm！"
      fi
    done
  else
    if [[ ${mode_map[$dm_install_mode]+exists} ]]; then
      printf "\n"
      dm_install_mode=${mode_map[$dm_install_mode]}
      color_printf green "达梦数据库安装部署类型: $dm_install_mode"
    else
      printf "\n"
      color_printf red "达梦数据库部署类型选择错误，请输入 si 或 dw 或 dsc 或 dscm！"
      printf "\n"
      exit 1
    fi
  fi
}
#==============================================================#
# 准备开始安装数据库
#==============================================================#
function begin_install_dmdb() {
  # 单节点安装配置
  if [[ $node_num -eq 1 ]]; then
    case $dm_install_mode in
    "single")
      # 判断是否需要配置 NTP 时间同步服务
      if [[ -n $timeserver_ip && $iso == "Y" ]]; then
        conf_yum
      fi
      ;;
    "datawatch")
      # 数据守护模式安装时必填的参数
      if { [ -z "$root_passwd" ] && [ -z "$ssh_key_path" ]; } || [ -z "$db_public_ip" ] || [ -z "$db_mal_ip" ]; then
        printf "\n"
        color_printf red "数据守护集群安装模式必须设置以下参数：-rp[-skp], -dpi, -dmi！"
        printf "\n"
        exit 1
      fi
      # 检查节点数是否符合要求
      if [[ ${#all_pubip_arr[@]} -lt 2 || ${#all_pubip_arr[@]} -gt 24 ]]; then
        printf "\n"
        color_printf red "节点数必须在 2 到 24 个之间！"
        printf "\n"
        exit 1
      fi
      # 安装配置
      [[ $iso == "Y" ]] && conf_yum
      [ -z "$ssh_key_path" ] && [[ "$is_sshpass" =~ [Nn] ]] && user_ssh_trust
      send_node_scripts
      ;;
    "dsc" | "dscm")
      # DSC 集群安装必填参数
      # 定义变量保存判断结果
      condition_true=false
      if { [ -z "$root_passwd" ] && [ -z "$ssh_key_path" ]; } || [ -z "$db_public_ip" ] || [ -z "$db_mal_ip" ] || [ -z "$dcr_disk" ] || [ -z "$data_disk" ]; then
        condition_true=true # 条件成立时，赋值为 true
      fi
      if [[ $dm_install_mode == "dsc" ]]; then
        if [[ $condition_true == "true" ]] || [ -z "$data_disk" ]; then
          printf "\n"
          color_printf red "DSC集群安装模式必须设置以下参数：-rp[-skp], -dpi, -dmi, -dcd, -vod, -dad！"
          printf "\n"
          exit 1
        fi
      else
        if [[ $condition_true == "true" ]]; then
          printf "\n"
          color_printf red "DSCM集群安装模式必须设置以下参数：-rp[-skp], -dpi, -dmi, -dcd, -dad！"
          printf "\n"
          exit 1
        fi
      fi
      # 校验磁盘数量和冗余模式是否匹配
      [[ $dm_install_mode == "dscm" ]] && parse_disks_redun
      # 检查节点数是否符合要求
      if [[ ${#all_pubip_arr[@]} -lt 2 || ${#all_pubip_arr[@]} -gt 16 ]]; then
        printf "\n"
        color_printf red "节点数必须在 2 到 16 个之间！"
        printf "\n"
        exit 1
      fi
      # 安装配置
      [[ $iso == "Y" ]] && conf_yum
      [ -z "$ssh_key_path" ] && [[ "$is_sshpass" =~ [Nn] ]] && user_ssh_trust
      send_node_scripts
      ;;
    esac
  else
    # 多节点安装配置
    if [[ $dm_install_mode =~ ^(datawatch|dsc|dscm)$ ]]; then
      if [ -n "$timeserver_ip" ] || { [ "$multipath" == "Y" ] && [[ "$data_disk" =~ "dev" ]]; }; then
        [[ $iso == "Y" ]] && conf_yum
      fi
    fi
  fi
}
