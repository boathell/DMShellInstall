  fi
  color_printf blue "主库进行脱机 dmrman 备份："
  printf "\n"
  run_cmd su - dmdba -c "$env_dm_home/bin/dmrman use_ap=2 CTLSTMT=\"BACKUP DATABASE '$data_dir/$db_name/dm.ini' FULL TO BACKUP_FILE1 BACKUPSET '$backup_dir/$db_name/BACKUP_FILE_01'\""
  printf "\n"
  color_printf blue "主库查看脱机备份文件："
  printf "\n"
  run_cmd ls -la "$backup_dir/$db_name"/BACKUP_FILE_01
