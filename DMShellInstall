#==============================================================#
# 配置multipath_rules
#==============================================================#
function dsc_multipath_rules() {
  # 创建规则函数，根据规则类型动态处理
  function create_rule() {
    local rule_type=$1    # 规则类型（如 multipath、symlink、scsi_id 等）
    local device_name=$2  # 设备名称
    local symlink_name=$3 # 符号链接名称
    # shellcheck disable=SC2155
    local uuid=$(get_wwid "$device_name") # 根据设备获取 UUID
    # 根据不同的规则类型，生成对应的规则
    case $rule_type in
    multipath)
      # 配置 multipath.conf
      run_cmd printf "  multipath {\n    wwid   \"%s\"\n    alias  %s\n  }\n" "$uuid" "$symlink_name" | run_cmd tee -a "$MULTIPATH_CONF_PATH"
      ;;
    symlink)
      # 创建符号链接规则
      run_cmd printf "KERNEL==\"dm-*\", ENV{DM_UUID}==\"%s\", SYMLINK+=\"asmdisk/%s\", OWNER=\"dmdba\", GROUP=\"dinstall\", MODE=\"0660\"\n" "mpath-${uuid}" "$symlink_name" | run_cmd tee -a "$rules_file" >/dev/null
      ;;
    scsi_id)
      # 创建 SCSI ID 规则
      run_cmd printf "KERNEL==\"sd*|vd*\", BUS==\"scsi\", PROGRAM==\"/sbin/scsi_id -g -u -d /dev/\$name\", RESULT==\"%s\", SYMLINK+=\"asmdisk/%s\", OWNER=\"dmdba\", GROUP=\"dinstall\", MODE=\"0660\"\n" "$uuid" "$symlink_name" | run_cmd tee -a "$rules_file" >/dev/null
      ;;
    device)
      # 创建设备规则
      run_cmd printf "KERNEL==\"sd*|vd*\", ENV{ID_PART_ENTRY_UUID}==\"%s\", SYMLINK+=\"asmdisk/%s\", OWNER=\"dmdba\", GROUP=\"dinstall\", MODE=\"0660\"\n" "$uuid" "$symlink_name" | run_cmd tee -a "$rules_file" >/dev/null
      ;;
    block)
      # 创建块设备规则
      run_cmd printf "KERNEL==\"sd*|vd*\", SUBSYSTEM==\"block\", PROGRAM==\"/usr/lib/udev/scsi_id -g -u -d /dev/\$name\", RESULT==\"%s\", SYMLINK+=\"asmdisk/%s\", OWNER=\"dmdba\", GROUP=\"dinstall\", MODE=\"0660\"\n" "$uuid" "$symlink_name" | run_cmd tee -a "$rules_file" >/dev/null
      ;;
    esac
  }
  # 遍历磁盘数组并创建符号链接规则
  function create_symlinks_for_disks() {
    local rule_type=$1 # 规则类型
    for ((x = 0; x < ${#disk_arr[@]}; x++)); do
      local y=1 # 符号链接的编号
      for i in ${disk_arr[$x]//,/ }; do
        # 调用 create_rule 动态创建规则
        create_rule "$rule_type" "$(lower "$i")" "${asm_disk_arr[$x]}$(printf "%02d" "$y")"
        y=$((y + 1)) # 编号递增
      done
    done
  }
  # 创建 UDEV 规则文件
  # 创建 UDEV 规则文件
  if [[ $multipath == "Y" ]]; then
    if [[ ${disk_arr[0]:0:4} == "/dev" ]]; then
      # 打印配置结果
      local config
      printf "\e[34m配置 %s ：\e[0m\n\n" "$MULTIPATH_CONF_PATH"

      # 配置 multipath.conf
      config=$(
        cat <<'EOF'
defaults {
  polling_interval        30
  failback                immediate
  no_path_retry           5
  rr_min_io               100
  path_checker            tur
  user_friendly_names     yes
}

blacklist {
  devnode "^(ram|raw|loop|fd|md|dm-|sr|scd|st)[0-9]*"
  devnode "^(hd|xvd)[a-z]*"
}

multipaths {
EOF
      )
      run_cmd printf "%s\n" "$config" | run_cmd tee "$MULTIPATH_CONF_PATH"

      # 遍历磁盘数组，创建 multipath.conf 配置
      create_symlinks_for_disks "multipath"

      # 获取磁标识等信息并补充配置
      config=$(
        cat <<EOF
}

devices {
  device {
    vendor "$(xargs </sys/class/block/"${disk_arr[0]##*/}"/device/vendor)"
    product "$(xargs </sys/class/block/"${disk_arr[0]##*/}"/device/model)"
    path_grouping_policy group_by_prio
    prio const
  }
}
EOF
      )
      # 追加配置到 multipath.conf 文件中
      run_cmd printf "%s\n" "$config" | run_cmd tee -a "$MULTIPATH_CONF_PATH"
      printf "\n"
    fi
    create_symlinks_for_disks "symlink"
  else
    # 创建非 multipath 的规则文件
    if [[ $os_version -eq 6 ]]; then
      create_symlinks_for_disks "scsi_id"
    else
      if [[ ${disk_arr[0]} =~ [0-9] ]]; then
        create_symlinks_for_disks "device"
      else
        create_symlinks_for_disks "block"
      fi
    fi
  fi
}
#==============================================================#
# ASM 磁盘(操作系统级别)
#==============================================================#
function dsc_conf_disk_arr() {
  # 根据节点数量打印操作日志
  if [[ $node_num -gt 1 ]]; then
    log_print "拷贝 ASM 磁盘(操作系统级别)配置文件"
  else
    log_print "创建 ASM 磁盘(操作系统级别)配置文件"
  fi
  # 确定规则文件路径
  local rules_file
  if [[ $multipath == "Y" && ${disk_arr[0]:0:4} == "/dev" ]]; then
    rules_file="$UDEV_RULES_PATH/$DM_PERMISSIONS_RULES"
  else
    rules_file="$UDEV_RULES_PATH/$DM_ASMDEVICES_RULES"
  fi
  # 备份并删除现有规则文件
  bak_file "$rules_file" && rm -f "$rules_file"
  # 安装 multipath 工具（如果需要）
  if [[ $multipath == "Y" && ${disk_arr[0]:0:4} == "/dev" ]] && ! command -v multipath &>/dev/null; then
    install_package "device-mapper-multipath"
    run_cmd mpathconf --enable --with_multipathd y
  fi
  # 根据节点数量执行操作
  if [[ "$node_num" -eq 1 ]]; then
    # 检查条件并创建符号链接规则
    if [[ $(
      find /dev/ -maxdepth 1 \( -user "dmdba" -or -group "dinstall" \) >/dev/null 2>&1
      echo $?
    ) -eq 0 ]] ||
      [[ ! -d $ASM_DEVICE_PATH || $(find "$ASM_DEVICE_PATH" -mindepth 1 -name 'dm*' | wc -l) -eq 0 ]]; then
      dsc_multipath_rules
    fi
  else
    # 其他节点，拷贝配置文件
    if [[ $multipath == "Y" && ${disk_arr[0]:0:4} == "/dev" ]]; then
      exec_scp_cmd "$MULTIPATH_CONF_PATH" "${all_pubip_arr[0]}" "$MULTIPATH_CONF_PATH" "DOWN"
      # 打印配置结果
      printf "\e[34m配置 %s ：\e[0m\n\n%s\n" "$MULTIPATH_CONF_PATH" "$(cat $MULTIPATH_CONF_PATH)"
      printf "\n"
    fi
    exec_scp_cmd "$rules_file" "${all_pubip_arr[0]}" "$rules_file" "DOWN"
  fi
  # 打印配置结果
  printf "\e[34m配置 %s ：\e[0m\n\n%s\n" "$rules_file" "$(cat $rules_file)"
}
#==============================================================#
# 配置udev生效
#==============================================================#
function dsc_start_udev() {
  local WAIT_TIME="5s" # 等待时间
  if [[ $multipath == "Y" && ${disk_arr[0]:0:4} == "/dev" ]]; then
    log_print "查看multipath聚合磁盘" # 打印查看multipath聚合磁盘的信息
    # 配置多路径开机自启
    if [[ "$os_version" -eq 6 ]]; then
      run_cmd service multipathd restart >/dev/null 2>&1
      run_cmd chkconfig multipathd on >/dev/null 2>&1
    else
      run_cmd systemctl restart multipathd -q
      run_cmd systemctl enable multipathd -q
    fi
    # 使用函数优化逻辑
    run_cmd multipath -F >/dev/null 2>&1
    run_cmd multipath -r >/dev/null 2>&1
    run_cmd multipath -ll
  fi
  # 启动udev
  while true; do
    if [[ $os_version -eq 6 ]]; then
      printf "\n"
      run_cmd start_udev # 在CentOS 6上启动udev服务
    else
      run_cmd /sbin/udevadm control --reload-rules                 # 重新加载udev规则
      run_cmd /sbin/udevadm trigger --type=devices --action=change # 触发设备变化事件
    fi
    sleep "$WAIT_TIME"
    if [[ $(find $ASM_DEVICE_PATH -mindepth 1 -name 'dm*' | wc -l) -gt 0 ]]; then
      log_print "查看udev磁盘" # 打印查看udev磁盘的信息
      ls -lh $ASM_DEVICE_PATH
      break
    fi
  done
}
#==============================================================#
# 配置dmdcr_cfg.ini
#==============================================================#
function dsc_dmdcr_cfg() {
  local cfg_path="$data_dir/$dsc_db_name/dmdcr_cfg.ini"
  local ep_count=${#all_pubip_arr[@]}
  local config
  # 写入基础配置内容
  function write_basic_cfg() {
    if [[ $dm_install_mode == "dsc" ]]; then
      config=$(
        cat <<EOF
DCR_N_GRP = 3
DCR_VTD_PATH = $ASM_DEVICE_PATH/${asm_disk_arr[1]}01
DCR_OGUID = $oguid
EOF
      )
    else
      config=$(
        cat <<EOF
DCR_N_GRP = 3
DCR_DISK_LOAD_PATH = $ASM_DEVICE_PATH
DCR_OGUID = $oguid
EOF
      )
    fi
  }
  # 存储节点配置信息的关联数组
  declare -A groups=(
    ["CSS"]="DCR_GRP_TYPE = CSS
DCR_GRP_NAME = GRP_CSS
DCR_GRP_N_EP = $ep_count
DCR_GRP_DSKCHK_CNT = 60"
    ["ASM"]="DCR_GRP_TYPE = ASM
DCR_GRP_NAME = GRP_ASM
DCR_GRP_N_EP = $ep_count
DCR_GRP_DSKCHK_CNT = 60"
    ["DB"]="DCR_GRP_TYPE = DB
DCR_GRP_NAME = GRP_${dsc_db_name}
DCR_GRP_N_EP = $ep_count
DCR_GRP_DSKCHK_CNT = 60"
  )
  # 写入各组的通用信息
  function write_group_info() {
    local group=$1
    local group_info="${groups[$group]}"
    group_info=$(eval "echo \"$group_info\"")
    if [[ -n "$group_info" ]]; then
      config+=$(
        cat <<EOF

[GRP]
$group_info
EOF
      )
    fi
  }
  # 写入CSS、ASM和DB的端点信息
  function write_endpoints() {
    local group_name=$1
    # shellcheck disable=SC2155
    for ((x = 1; x <= ep_count; x++)); do
      local ep_host="${malip_host_arr[$((x - 1))]}"
      local ep_name="${group_name}$(printf "%02d" "$x")"

      case $group_name in
      "CSS")
        config+=$(
          cat <<EOF

[GRP_CSS]
DCR_EP_NAME = $ep_name
DCR_EP_HOST = $ep_host
DCR_EP_PORT = $css_dcr_ep_port
EOF
        )
        ;;
      "ASM")
        config+=$(
          cat <<EOF

[GRP_ASM]
DCR_EP_NAME = $ep_name
DCR_EP_SHM_KEY = 789$(printf "%02d" "$x")
DCR_EP_SHM_SIZE = 512
DCR_EP_HOST = $ep_host
DCR_EP_PORT = $asm_dcr_ep_port
EOF
        )
        if [[ $dm_install_mode == "dsc" ]]; then
          config+=$(
            cat <<EOF

DCR_EP_ASM_LOAD_PATH = $ASM_DEVICE_PATH
EOF
          )
        fi
        ;;
      "DB")
        config+=$(
          cat <<EOF

[GRP_${dsc_db_name}]
DCR_EP_NAME = $(upper "${dsc_ep_name}$(printf "%02d" "$x")")
DCR_EP_SEQNO = $((x - 1))
DCR_EP_PORT = $port_num
DCR_CHECK_PORT = $db_dcr_ep_port
EOF
        )
        ;;
      esac
    done
  }
  # 创建新的配置文件
  function create_config_file() {
    write_basic_cfg
    for group in CSS ASM DB; do
      write_group_info "$group"
      write_endpoints "$group"
    done
    # 使用su切换用户并执行命令
    run_cmd su - dmdba <<-DMDCR_CFG
printf "%s\n" "$config" | tee "$cfg_path"
DMDCR_CFG
  }
  # 复制现有的配置文件
  function copy_config_file() {
    exec_scp_cmd "$cfg_path" "${all_pubip_arr[0]}" "$cfg_path" "DOWN"
    run_cmd chown -R dmdba:dinstall "$cfg_path"
    cat "$cfg_path"
  }
  # 主逻辑
  if [[ $node_num -eq 1 ]]; then
    log_print "配置 dmdcr_cfg.ini"
    create_config_file
  else
    log_print "拷贝 dmdcr_cfg.ini"
    copy_config_file
  fi
}
