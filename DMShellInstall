    declare -a flags=("-dmi" "-ami" "-smi")
    declare -A ip_sets=(
      ["-dmi"]="${db_malip_arr[@]}"
      ["-ami"]="${as_malip_arr[@]}"
      ["-smi"]="${sy_malip_arr[@]}"
    )
    check_ip_in_flags
