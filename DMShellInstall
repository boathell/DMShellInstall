#==============================================================#
# 安装rpm包
#==============================================================#
function install_package() {
  for package in "$@"; do
    if ! run_cmd rpm -q "$package" >/dev/null; then
      run_cmd yum install -y -q "$package" --skip-broken >/dev/null 2>&1
      # 判断安装是否成功
      if [ $? -ne 0 ]; then
        # 如果安装失败，输出错误信息
        printf "\n"
        color_printf red "安装 $package 失败，请检查YUM源配置"
        printf "\n"
        exit 1
      fi
    fi
  done
}
#==============================================================#
# 安装sshpass包
#==============================================================#
function install_sshpass() {
  log_print "开始安装 sshpass 插件"
  # 检查是否已安装 sshpass
  if command -v sshpass >/dev/null 2>&1; then
    color_printf green "已存在 sshpass：" "$(sshpass -V)"
    printf "\n"
    exit 0 # 如果已安装，返回成功
  fi
  # 检查是否安装 gcc
  if ! command -v gcc >/dev/null 2>&1; then
    # 配置YUM源
    conf_yum
    # 安装 gcc
    install_package "gcc" || {
      color_printf red "gcc 安装失败"
      exit 1
    }
  fi
  # 检查 sshpass 安装包是否存在
  if ! ls "$software_dir"/sshpass-*.tar.gz >/dev/null 2>&1; then
    color_printf red "不存在 sshpass.tar.gz 安装包，请下载安装包，放置到 $software_dir 目录下"
    exit 1
  fi
  # 定义安装目录
  local install_dir="$software_dir/sshpass"
  # 创建并进入安装目录
  /bin/mkdir -p "$install_dir" || {
    color_printf red "创建目录失败"
    exit 1
  }
  cd "$install_dir" || {
    color_printf red "无法进入目录 $install_dir"
    exit 1
  }
  # 解压 sshpass 安装包
  if ! tar -xf "$software_dir"/sshpass-*.tar.gz --strip-components 1 -C "$install_dir"; then
    color_printf red "解压安装包失败"
    exit 1
  fi
  # 配置、编译和安装
  color_printf green "配置、编译并安装 sshpass..."
  printf "\n"
  # 配置
  if ! ./configure --prefix=/usr/local --libdir=/usr/local/libexec >/dev/null 2>&1; then
    color_printf red "配置失败"
    exit 1
  fi
  # 编译
  if ! make -s >/dev/null 2>&1; then
    color_printf red "编译失败"
    exit 1
  fi
  # 安装
  if ! make install -s >/dev/null 2>&1; then
    color_printf red "安装失败"
    exit 1
  fi
  # 清理工作：删除临时目录
  rm -rf "$install_dir"
  # 验证是否成功安装
  if command -v sshpass >/dev/null 2>&1; then
    color_printf green "成功安装 sshpass：" "$(sshpass -V)"
  else
    color_printf yellow "未能成功安装 sshpass，请检查安装日志。"
    exit 1
  fi
  printf "\n"
  exit 0 # 成功安装
}
#==============================================================#
# 远程执行命令
#==============================================================#
function exec_ssh_cmd() {
  local node="$1"                                                    # 目标主机
  local cmd="$2"                                                     # 要执行的命令
  local ssh_cmd="ssh -o StrictHostKeyChecking=no -q -p $os_ssh_port" # SSH 命令
  # 使用现有的免密认证
  if [[ -n "$ssh_key_path" ]]; then
    # 确保密钥路径没有尾部斜杠，并且添加双引号来处理路径中的空格
    ssh_cmd="$ssh_cmd -i \"${ssh_key_path%/}/id_rsa\""
  fi
  # 如果设置了 is_sshpass，使用 sshpass 提供密码认证
  if [[ "$is_sshpass" =~ [Yy] ]]; then
    # 使用 sshpass 提供密码认证
    # shellcheck disable=SC2089
    ssh_cmd="sshpass -p \"$root_passwd\" $ssh_cmd"
  fi
  # 执行 SSH 命令，注意：$ssh_cmd 不要加双引号，否则会出现转义错误
  # shellcheck disable=SC2090
  # shellcheck disable=SC2086
  $ssh_cmd "$node" "$cmd"
  local status=$?
  # 检查命令执行状态
  if [ $status -ne 0 ]; then
    printf "错误：命令 '%s' 在主机 '%s' 上执行失败，退出码为 %d。\n" "$cmd" "$node" "$status"
    return $status
  fi
}
#==============================================================#
# 使用scp发送文件到目标服务器
#==============================================================#
function exec_scp_cmd() {
  local file_name="$1"
  local node="$2"
  local path="$3"
  local UP_OR_DOWN="$4"
  local scp_cmd="scp -o StrictHostKeyChecking=no -p -q -P $os_ssh_port -r"
  # 使用现有的免密认证
  if [[ -n "$ssh_key_path" ]]; then
    # 确保路径没有以斜杠结尾，并避免路径问题
    scp_cmd="$scp_cmd -i ${ssh_key_path%/}/id_rsa"
  fi
  # 检查是否设置了 is_sshpass 环境变量来进行密码认证
  if [[ "$is_sshpass" =~ [Yy] ]]; then
    # 使用 sshpass 进行密码认证
    scp_cmd="sshpass -p $root_passwd $scp_cmd"
  fi
  # 根据 UP_OR_DOWN 参数执行上传或下载操作，注意：$scp_cmd 不要加双引号，否则会出现转义错误
  case "$UP_OR_DOWN" in
  "UP")
    # 上传：从本地服务器上传到远程服务器
    # shellcheck disable=SC2090
    # shellcheck disable=SC2086
    $scp_cmd "$file_name" "$node:$path"
    ;;
  "DOWN")
    # 下载：从远程服务器下载到本地服务器
    # shellcheck disable=SC2090
    # shellcheck disable=SC2086
    $scp_cmd "$node:$path" "$file_name"
    ;;
  *)
    printf "操作无效。请使用 'UP' 或 'DOWN'。\n"
    return 1
    ;;
  esac
}
#==============================================================#
# 使用sftp发送文件到目标服务器
#==============================================================#
function sftp_cmd() {
  local sftp_server_ip=$1
  local sftp_server_port=$2
  local sftp_username=$3
  # shellcheck disable=SC2155
  local sftp_passwd=$(printf "%q" "$4")
  # shellcheck disable=SC2155
  local sftp_path=$5
  local remote_path=$6
  local cmd=$7
  # 确保路径包含空格或特殊字符时不会出错
  sftp_path=$(printf "%q" "$sftp_path")
  remote_path=$(printf "%q" "$remote_path")
  # 公共的 expect 脚本模板
  expect_script="
  log_user 0
  spawn sftp -o StrictHostKeyChecking=no -P $sftp_server_port $sftp_username@$sftp_server_ip
  expect \"password:\"
  send \"$sftp_passwd\r\"
  expect \"sftp>\"
  send \"cd $sftp_path\r\"
  expect \"sftp>\"
  send \"lcd $remote_path\r\"
  expect \"sftp>\"
  "
  case "$cmd" in
  "UP")
    # 上传操作
    expect_script+="
    send \"mkdir -p dmdir\r\"
    expect \"sftp>\"
    send \"cd dmdir\r\"
    expect \"sftp>\"
    send \"rm *\r\"
    expect \"sftp>\"
    send \"put -r *\r\"
    expect \"sftp>\"
    send \"quit\r\"
    "
    ;;
  "DOWN")
    # 下载操作
    expect_script+="
    send \"cd dmdir\r\"
    expect \"sftp>\"
    send \"get -r *\r\"
    expect \"sftp>\"
    send \"quit\r\"
    "
    ;;
  *)
    printf "无效的命令！\n"
    exit 1
    ;;
  esac
  # 执行 expect 脚本并检查执行结果
  expect -c "$expect_script"
}
