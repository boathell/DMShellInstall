#==============================================================#
# 配置数据库归档
#==============================================================#
function creat_arch() {
  log_print "配置数据库归档"
  # 分布式节点配置归档
  function create_archive() {
    local node="$1"
    local number="$2"
    printf "\n"
    color_printf blue "在节点 ${node} 创建归档"
    printf "\n"
    # 在远程节点执行归档脚本
    exec_ssh_cmd "${node}" "
      scripts_dir='${scripts_dir}'
      env_dm_home='${env_dm_home}'
      port_num='${port_num}'
      sysdba_pwd_temp='${sysdba_pwd_temp}'
      $(declare -f run_cmd)
      $(declare -f execute_script)
      execute_script \"SYSDBA\" \"${sysdba_pwd_temp}\" \"conf_arch.sql\"
    "
    # 配置 `dmarch.ini` 参数（仅限 `dscm` 模式）
    if [[ $dm_install_mode == "dscm" && $is_local_arch =~ [Nn] && -n $arch_disk ]]; then
      exec_ssh_cmd "${node}" "sed -i '6i ARCH_ASM_MIRROR=$arch_asm_mirror\nARCH_ASM_STRIPING=$arch_asm_striping\n' ${data_dir}/${dsc_db_name}/${dsc_ep_name}$(printf "%02d" "$((number + 1))")_config/dmarch.ini"
      if [[ $? -ne 0 ]]; then
        color_printf red "在节点 ${node} 修改 dmarch.ini 配置失败"
      fi
    fi
  }
  # 主逻辑
  if [[ $dm_install_mode == "single" ]]; then
    execute_script "SYSDBA" "$sysdba_pwd_temp" "conf_arch.sql"
  elif [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
    config_file="${data_dir}/${dsc_db_name}/${dsc_ep_name}$(printf "%02d" "$node_num")_config/dm.ini"
    if pgrep -f "$config_file" >/dev/null; then
      check_db_status "OPEN"
    fi
    # 遍历所有节点，逐一配置归档
    for ((x = 0; x < ${#all_pubip_arr[@]}; x++)); do
      if ! create_archive "${all_pubip_arr[$x]}" "$x"; then
        color_printf red "节点 ${all_pubip_arr[$x]} 归档配置失败，跳过"
      fi
    done
  fi
}
#==============================================================#
# 优化数据库
#==============================================================#
function optimize_dmdb() {
  local WAIT_TIME="5s" # 等待时间
  # 配置数据库归档
  function enable_archiving() {
    if [[ $enable_arch = "Y" && $dm_install_mode =~ ^(single|dsc|dscm)$ ]]; then
      creat_arch
    fi
  }
  # 创建数据库备份
  function backup_if_enabled() {
    local ip=${1}
    if [[ $enable_arch = "Y" ]]; then
      log_print "在 ${ip} 创建备份"
      if [[ $backup_mode -eq 1 ]]; then
        execute_script "SYSDBA" "$sysdba_pwd_temp" "conf_fullbackup.sql"
      elif [[ $backup_mode -eq 2 ]]; then
        execute_script "SYSDBA" "$sysdba_pwd_temp" "conf_incrbackup.sql"
      fi
    fi
  }
  # 创建搜集统计信息作业
  function conf_stat_job() {
    if [[ $node_num -eq 1 ]]; then
      log_print "配置搜集统计信息作业"
      if [[ $enable_arch = "N" ]]; then
        execute_sql "SYSDBA" "$sysdba_pwd_temp" "SP_INIT_JOB_SYS(1);"
      fi
      execute_script "SYSDBA" "$sysdba_pwd_temp" "conf_statistics.sql"
    fi
  }
  # 优化数据库基础参数
  function optimize__dmini() {
    log_print "优化数据库基础参数"
    execute_script "SYSDBA" "$sysdba_pwd_temp" "conf_dmini.sql"
    if [[ $compatible_mode -ne 0 ]]; then
      log_print "打开兼容 $compatible_mode 参数"
      execute_sql "SYSDBA" "$sysdba_pwd_temp" "sp_set_para_value(2,'COMPATIBLE_MODE',${compatible_mode});"
      printf "\n"
      color_printf yellow "请查看脚本 ${scripts_dir}/conf_com_mod.sql ，自行判断是否需要执行此脚本"
    fi
  }
  # 开启操作系统认证
  function conf_osauth() {
    if [[ $os_auth =~ [Nn] ]]; then
      return
    fi
    log_print "开启操作系统认证"
    execute_sql "SYSDBA" "$sysdba_pwd_temp" "sp_set_para_value(2,'ENABLE_LOCAL_OSAUTH',1);"
  }
  # 开启SQLLOG日志
  function conf_sql_log() {
    log_print "开启SQLLOG日志"
    execute_sql "SYSDBA" "$sysdba_pwd_temp" "sp_set_para_value(2,'SVR_LOG',1);"
  }
  # 修改计算方法
  function conf_cal_method() {
    log_print "修改整数计算方式"
    execute_sql "SYSDBA" "$sysdba_pwd_temp" "sp_set_para_value(2,'CALC_AS_DECIMAL',1);"
  }
  # 重启数据库使优化参数生效
  function restart_database() {
    log_print "重启数据库，优化参数生效"
    if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
      color_printf red "关闭数据库"
      # 进程路径
      config_file="$data_dir/$dsc_db_name/$dsc_ep_name$(printf "%02d" "$node_num")_config/dm.ini"
      printf "\n"
      su - dmdba -c "$env_dm_home/bin/dmcssm $data_dir/$dsc_db_name/dmcssm.ini" <<-DMCSSM
ep stop GRP_$dsc_db_name
exit
DMCSSM
      # 等待进程结束
      while true; do
        sleep "$WAIT_TIME"
        PID=$(pgrep -f "$config_file")
        [ ! "$PID" ] && break
      done
      color_printf blue "启动数据库"
      printf "\n"
      su - dmdba -c "$env_dm_home/bin/dmcssm $data_dir/$dsc_db_name/dmcssm.ini" <<-DMCSSM
ep startup GRP_$dsc_db_name
exit
DMCSSM
      if pgrep -f "$config_file" >/dev/null; then
        check_db_status "OPEN"
      fi
    else
      run_cmd su - dmdba -c "$DMS_RESTART_CMD"
    fi
  }
  # 开始优化过程
  enable_archiving
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
    local length=${#all_pubip_arr[@]}
    backup_if_enabled "${all_pubip_arr[$((length - 1))]}"
  elif [[ $dm_install_mode == "datawatch" && $node_num -eq 1 ]]; then
    backup_if_enabled "${all_pubip_arr[0]}"
  else
    backup_if_enabled "$(hostname -I | xargs | awk '{print $1}')"
  fi
  conf_stat_job
  optimize__dmini
  conf_osauth
  conf_sql_log
  conf_cal_method
  restart_database
}
#==============================================================#
# 修改数据库用户口令
#==============================================================#
function mod_db_mess() {
  log_print "修改管理员用户密码"
  declare -A user_pwd

  # 通用函数：修改数据库用户密码
  function change_pwd() {
    local user="$1"
    local passwd="$2"
    local script_file="$3"
    # shellcheck disable=SC2155
    local alter_user_sql=$(
      cat <<EOF
set timing off
set lineshow off
set feedback off
set define off
-- 修改 ${user} 密码
alter user \"${user}\" identified by \"${passwd}\" password_policy 31 limit failed_login_attemps unlimited, password_life_time unlimited, password_lock_time unlimited;
-- 查看密码策略
select so.name,
       su.failed_num,
       su.life_time,
       su.lock_time
  from sysobjects so,
       sysusers su
 where so.id = su.id
   and so.name = '${user}';
exit;
EOF
    )
    run_cmd su - dmdba <<-SQL
printf "%s\n" "$alter_user_sql" | tee "${scripts_dir}/${script_file}" >/dev/null
SQL
  }

  # 确定数据库状态是否为 OPEN 状态
  check_db_status "OPEN"

  # 通用密码修改函数
  function modify_pwd() {
    local user=$1
    local input_pwd=$2
    local sql_file=$3
    local passwd_temp passwd
    # 密码生成逻辑优化，避免重复
    case $user in
    "SYSDBA")
      passwd_temp="${sysdba_pwd:-$(gen_password)}"
      sysdba_pwd="$passwd_temp"
      ;;
    "SYSAUDITOR")
      passwd_temp="${sysaud_pwd:-$(gen_password)}"
      sysaud_pwd="$passwd_temp"
      ;;
    "SYSSSO")
      passwd_temp="${syssso_pwd:-$(gen_password)}"
      syssso_pwd="$passwd_temp"
      ;;
    *)
      echo "未知用户：$user"
      return 1
      ;;
    esac
    # 保持密码唯一性(重要)
    passwd="$passwd_temp"
    # 将密码添加到关联数组里面
    user_pwd["$user"]="$passwd"
    # 修改密码
    change_pwd "$user" "$passwd" "$sql_file"        # 修改密码
    color_printf blue "修改${user}密码： \"${passwd}\" " # 打印日志
    printf "\n"
    execute_script "$user" "$input_pwd" "$sql_file" # 执行脚本
    printf "\n"
  }
  modify_pwd "SYSDBA" "$sysdba_pwd_temp" "alter_sysdba.sql"
  if [[ "$db_flag" == "true" ]]; then
    modify_pwd "SYSSSO" "$syssso_pwd_temp" "alter_syssso.sql"
  fi
  modify_pwd "SYSAUDITOR" "$sysauditor_pwd_temp" "alter_sysaud.sql"

  # 备份和查询数据库基础信息
  declare -A tasks=(
    ["check_backup.sql"]="备份数据库"
    ["basic_dbinfo.sql"]="查询数据库基础参数信息"
    ["query_dmini.sql"]="查询数据库优化结果"
  )
  # 定义脚本的执行顺序
  script_order=("check_backup.sql" "basic_dbinfo.sql" "query_dmini.sql")
  # 循环执行任务（按顺序）
  for script_name in "${script_order[@]}"; do
    local task_name="${tasks[$script_name]}"
    log_print "$task_name"                                         # 打印任务描述
    execute_script "SYSDBA" "${user_pwd["SYSDBA"]}" "$script_name" # 执行脚本
  done
  # 定义用户顺序数组
  user_order=("SYSDBA" "SYSSSO" "SYSAUDITOR")
  # 提示用户妥善保管密码
  log_print "请妥善保管密码，如果遗失，无法找回。"
  # 遍历数组并打印关联数组中的键值对
  for key in "${user_order[@]}"; do
    # 检查 user_pwd 关联数组中是否有对应的键
    if [[ -n "${user_pwd[$key]}" ]]; then
      # 打印用户和对应的密码
      printf "用户 [%s] 的密码是: \033[1;31m%s\033[0m\n\n" "$key" "${user_pwd[$key]}"
    fi
  done
}
#==============================================================#
# 重启服务器
#==============================================================#
function restart_hosts() {
  # 定义数据库服务关闭函数
  function restart_host() {
    local host="$1"
    local stop_cmd="$2"
    color_printf red "正在关闭 ${host} 节点数据库服务......"
    printf "\n"
    exec_ssh_cmd "$host" "su - dmdba -c \"${stop_cmd}\""
    printf "\n"
  }
  # 重启操作系统和数据库服务
  function restart_os_db() {
    local stop_cmd="$1"
    for ((x = 0; x < ${#db_pubip_arr[@]} + ${#as_pubip_arr[@]} + ${#sy_pubip_arr[@]}; x++)); do
      ip="${all_pubip_arr[x]}"
      restart_host "${ip}" "$stop_cmd"
      if ((x > 0)); then
        exec_ssh_cmd "${ip}" "shutdown -r now &"
        printf "\n"
      fi
    done
    # 当前节点最后重启
    shutdown -r now &
    printf "\n"
  }
  # 选择输入的Y或者N
  function prompt_input() {
    local message="$1"
    local user_choice
    read -rep "$(echo -e "\033[1;34m${message} [Y/N] \E[0m")" user_choice
    printf "\n"
    # 匹配 Yy 继续执行脚本。
    if [[ $user_choice =~ ^[Yy]$ ]]; then
      # 返回函数
      return 0
    elif [[ -z $user_choice || $user_choice =~ ^[Nn]$ ]]; then # 匹配到Nn之后，退出脚本
      color_printf yellow "操作已取消，请在合适的时间重启数据库服务器和数据库"
      printf "\n"
      exit 1
    else
      color_printf red "无效输入，请输入 Y 或 N"
      printf "\n"
      prompt_input "$message"
    fi
  }
  # 根据安装模式执行不同的重启操作
  case $dm_install_mode in
  "single")
    prompt_input "恭喜！单机安装成功，现在是否继续关闭数据库并重启主机？"
    color_printf red "正在关闭 $(hostname -I | xargs | awk '{print $1}') 节点数据库服务......"
    printf "\n"
    run_cmd su - dmdba -c "$DMS_STOP_CMD"
    printf "\n"
    shutdown -r now &
    ;;
  "datawatch")
    prompt_input "恭喜！数据守护集群安装成功，现在是否继续关闭数据库并重启主机？"
    # 如果监视器存在，关闭监视器
    if [[ -n "${dw_monitor_ip}" ]]; then
      restart_host "${dw_monitor_ip}" "$DMM_STOP_CMD"
      exec_ssh_cmd "${dw_monitor_ip}" "shutdown -r now &"
      printf "\n"
    fi
    # 关闭数据库实例节点并重启其他节点
    restart_os_db "$DMW_STOP_CMD && $DMS_STOP_CMD"
    ;;
  "dsc" | "dscm")
    prompt_input "恭喜！DSC集群安装成功，现在是否继续关闭数据库并重启主机？"
    # 关闭 DB 实例
    color_printf red "正在关闭 DB 实例......"
    printf "\n"
    su - dmdba -c "$env_dm_home/bin/dmcssm $data_dir/$dsc_db_name/dmcssm.ini" <<-EOF
ep stop GRP_$dsc_db_name
exit
EOF
    # 关闭 ASM 实例
    color_printf red "正在关闭 ASM 实例......"
    printf "\n"
    su - dmdba -c "$env_dm_home/bin/dmcssm $data_dir/$dsc_db_name/dmcssm.ini" <<-'EOF'
ep stop GRP_ASM
exit
EOF
    # 重启数据库节点和其他节点
    restart_os_db "$DMC_STOP_CMD"
    ;;
  esac
}
