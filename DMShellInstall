#==============================================================#
# 初始化磁盘
#==============================================================#
function dsc_dmasmcmd() {
  log_print "初始化 ASM 磁盘"
  # 初始化 ASM 磁盘路径变量
  local asm_disk_path=""
  # 初始化 ASM 磁盘路径集合变量
  local asm_disk_paths=""
  # 设置 ASM 磁盘配置文件路径
  local asm_disk_file="$data_dir/$dsc_db_name/asmdisk.txt"
  # 删除已存在的 ASM 磁盘配置文件
  rm -f "$asm_disk_file"
  # 创建 ASM 磁盘命令的函数
  function create_asm_disk() {
    local disk_type="$1"
    local disk_path="$2"
    local disk_name="$3"
    run_cmd printf "create %s '%s' '%s'\n" "$disk_type" "$disk_path" "$disk_name" | run_cmd tee -a "$asm_disk_file" >/dev/null
  }
  # 写入 ASM 脚本文件的头部注释信息
  printf "#asm script file\n" >"$asm_disk_file"
  # 遍历磁盘数组，生成磁盘配置命令
  for ((i = 0; i < ${#disk_arr[@]}; i++)); do
    IFS=',' read -ra disk_arr_temp <<<"${disk_arr[$i]}"
    for ((j = 1; j <= ${#disk_arr_temp[@]}; j++)); do
      asm_disk_name="${asm_disk_arr[$i]}$(printf '%02d' $j)"
      asm_disk_path="$ASM_DEVICE_PATH/$asm_disk_name"
      if [[ $dm_install_mode == "dsc" ]]; then
        # 根据不同的磁盘类型执行创建命令
        case $i in
        0) create_asm_disk "dcrdisk" "$asm_disk_path" "$asm_disk_name" ;;
        1) create_asm_disk "votedisk" "$asm_disk_path" "$asm_disk_name" ;;
        *) create_asm_disk "asmdisk" "$asm_disk_path" "$asm_disk_name" ;;
        esac
      else
        disk_type="$([ $i == 0 ] && echo 'dcrvdisk' || echo 'asmdisk')"
        create_asm_disk "$disk_type" "$asm_disk_path" "$asm_disk_name"
        # 如果是第一个磁盘，将路径添加到路径集合中
        if [[ $i == 0 ]]; then
          asm_disk_paths+="'$asm_disk_path',"
        fi
      fi
    done
  done
  # 生成 init 命令和执行
  if [[ $dm_install_mode == "dsc" ]]; then
    # 初始化 dcr 和 vote 磁盘
    run_cmd printf "init dcrdisk '$ASM_DEVICE_PATH/%s' from '$data_dir/$dsc_db_name/dmdcr_cfg.ini' identified by '$asm_pwd'\n" "${asm_disk_arr[0]}01" | run_cmd tee -a "$asm_disk_file" >/dev/null
    run_cmd printf "init votedisk '$ASM_DEVICE_PATH/%s' from '$data_dir/$dsc_db_name/dmdcr_cfg.ini'\n" "${asm_disk_arr[1]}01" | run_cmd tee -a "$asm_disk_file" >/dev/null
    # 以 dmdba 用户身份运行 asm 磁盘创建脚本
    run_cmd chown dmdba:dinstall "$asm_disk_file"
    run_cmd su - dmdba -c "$env_dm_home/bin/dmasmcmd script_file=$asm_disk_file"
  else
    # 去除路径集合变量末尾的逗号
    asm_disk_paths="${asm_disk_paths%,}"
    # 创建磁盘组的命令
    run_cmd printf "create system diskgroup asmdisk %s attribute config='$data_dir/$dsc_db_name/dmdcr_cfg.ini', passwd='$asm_pwd'\n" "$asm_disk_paths" | run_cmd tee -a "$asm_disk_file" >/dev/null
    # 以 dmdba 用户身份运行 asm 磁盘创建脚本
    run_cmd chown dmdba:dinstall "$asm_disk_file"
    run_cmd su - dmdba -c "$env_dm_home/bin/dmasmcmdm script_file=$asm_disk_file"
  fi
}
