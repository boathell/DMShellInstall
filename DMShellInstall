function dw_startup() {
  # 主备库启动到 mount 状态
  local WAIT_TIME="1s" # 等待时间
  if [[ $node_num -eq 1 ]]; then
    log_print "数据守护主库启动"
    color_printf blue "主库启动到 mount 状态："
  else
    log_print "数据守护备库启动"
    color_printf blue "备库启动到 mount 状态："
  fi
  printf "\n"
  run_cmd su - dmdba -c "$DMS_START_CMD mount"
  # 确认数据库状态是否为mount状态
  check_db_status "MOUNT"
  # 修改主备库模式
  printf "\n"
  function generate_sql_script() {
    local script_name="$1"
    local db_mode="$2"
    local config
    # 使用 Here Document (EOF) 来生成 SQL 脚本内容
    config=$(
      cat <<EOF
set echo off
set timing off
set feedback off
set lineshow off
sp_set_oguid($oguid);
alter database $db_mode;
SP_SET_PARA_VALUE(1, 'ALTER_MODE_STATUS', 0);
exit;
EOF
    )
    # 将生成的配置写入到 SQL 脚本文件
    run_cmd su - dmdba <<-DMMON
printf "%s" "$config" | tee "${scripts_dir}/${script_name}" >/dev/null
DMMON
  }
  if [[ $node_num -eq 1 ]]; then
    color_printf blue "主库修改模式："
    printf "\n"
    generate_sql_script "dw_conf_pri.sql" "primary"
    execute_script "SYSDBA" "$sysdba_pwd_temp" "dw_conf_pri.sql"
  else
    color_printf blue "备库修改模式："
    printf "\n"
    generate_sql_script "dw_conf_std.sql" "standby"
    execute_script "SYSDBA" "$sysdba_pwd_temp" "dw_conf_std.sql"
  fi
  # 启动守护进程
  printf "\n"
  if [[ $node_num -eq 1 ]]; then
    color_printf blue "主库启动守护进程："
  else
    color_printf blue "备库启动守护进程："
  fi
  printf "\n"
  run_cmd su - dmdba -c "$DMW_START_CMD"
}
