#==============================================================#
# 创建实例目录
#==============================================================#
function create_ins_dir() {
  # 根据数据库模式和状态决定要操作的数据库名称
  if [[ "$dm_install_mode" =~ ^(single|datawatch)$ ]]; then
    name="$db_name"
  else
    name="$(upper "$dsc_db_name")"
  fi # 如果是初始化数据库，且数据库已运行，则先杀掉进程
  if [[ $only_init_db =~ [Yy] ]] && pgrep -f "${name}" >/dev/null 2>&1; then
    pgrep -f "${name}" | grep -v "$$" | run_cmd xargs --no-run-if-empty kill -9
  fi
  # 检查并重命名 data_dir、backup_dir、arch_dir 和  "$core_dir" 子目录（如果存在）
  for dir in "$data_dir" "$backup_dir" "$arch_dir" "$core_dir"; do
    if [[ -d "$dir" ]]; then
      # 移动数据库目录，添加当前标识
      if [[ -d "${dir}/${name}" ]]; then
        run_cmd mv "${dir}/${name}" "${dir}/${name}${current}"
      fi
    else
      # 创建目录及其子目录
      run_cmd mkdir -m 755 -p "$dir"
      # 如果路径不包含 "/home/dmdba"，处理第二级路径权限
      if [[ "$dir" != *"/home/dmdba"* ]]; then
        second_path="$(awk -F'/' '{print "/"$2}' <<<"$dir")"
        if [ -d "$second_path" ]; then
          run_cmd chmod -R 755 "$second_path"
        fi
      fi
    fi
  done
  # 创建 scripts_dir 目录
  if [[ ! -d "$scripts_dir" ]]; then
    run_cmd mkdir -m 755 -p "$scripts_dir"
  fi
  # 确认监视器创建参数文件存放目录
  if [[ $dm_install_mode == "datawatch" && $node_num -eq -1 && ! -d "$data_dir/$db_name" ]]; then
    run_cmd mkdir -m 755 -p "$data_dir/$db_name"
  fi
  # 创建 DSC 模式相关目录
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ && ! -d "$data_dir/$(upper "$dsc_db_name")" ]]; then
    run_cmd mkdir -m 755 -p "$data_dir/$(upper "$dsc_db_name")"
  fi
  # 设置所有目录的权限和所有者
  run_cmd chown -R dmdba:dinstall "$data_dir" "$backup_dir" "$arch_dir" "$scripts_dir" "$core_dir"
}
#==============================================================#
# 初始化数据库实例
#==============================================================#
function init_database() {
  log_print "初始化达梦数据库"
  # 检查必要参数是否有效
  if [ -z "$data_dir" ] || [ -z "$db_name" ] || [ -z "$instance_name" ] || [ -z "$port_num" ]; then
    color_printf red "错误：必须提供 data_dir、db_name、instance_name 和 port_num 参数"
    exit 1
  fi
  # 检查大小写敏感和字符集参数（必填）
  if [ -z "$case_sensitive" ]; then
    color_printf red "错误：必须提供 -cs 参数（大小写敏感），可选值：Y/N 或 1/0"
    exit 1
  fi
  if [ -z "$charset" ]; then
    color_printf red "错误：必须提供 -c 参数（字符集），可选值：0[GB18030]、1[UTF-8]、2[EUC-KR]"
    exit 1
  fi
  # 数据守护集群配置：根据安装模式动态生成 instance_name
  if [[ "$dm_install_mode" == "datawatch" ]]; then
    prefix="${dw_group_name}_DW_"
    [[ "$instance_name" != "DMSERVER" ]] && prefix="$instance_name"
    instance_name="${prefix}$(printf "%02d" "$node_num")"
  fi
  # 设置数据库初始化命令的路径
  local dm_init_cmd="$env_dm_home/bin/dminit"
  # 构建初始化参数字符串
  local dm_init_para="PATH=$data_dir \
AUTO_OVERWRITE=2 \
EXTENT_SIZE=$extent_size \
PAGE_SIZE=$page_size \
CASE_SENSITIVE=$case_sensitive \
CHARSET=$charset \
LOG_SIZE=$log_size \
DB_NAME=$db_name \
INSTANCE_NAME=$instance_name \
PORT_NUM=$port_num \
BLANK_PAD_MODE=$blank_pad_mode \
SYSDBA_PWD='${sysdba_pwd_temp}' \
SYSAUDITOR_PWD='${sysauditor_pwd_temp}'"
  # 如果是安全版，将安全员的密码加进去
  if [[ "$db_flag" == "true" ]]; then
    dm_init_para="$dm_init_para SYSSSO_PWD='${syssso_pwd_temp}'"
  fi
  # 根据 length_in_char 参数动态添加
  if [[ $length_in_char =~ [Yy1] ]]; then
    dm_init_para="$dm_init_para LENGTH_IN_CHAR=$length_in_char"
  fi
  # 处理自定义参数
  if [[ -n "$dminit_para_value" ]]; then
    # 清理多余的空格并格式化为 "key=value" 形式
    dminit_para_value=$(echo "$dminit_para_value" | awk '{gsub(/ *= */, "="); print}')
    dm_init_para="$dm_init_para $dminit_para_value"
  fi
  # 执行 dminit 命令
  run_cmd su - dmdba -c "$dm_init_cmd $dm_init_para"
  # 检查执行结果
  if [ $? -ne 0 ]; then
    color_printf red "错误：执行 dminit 命令失败"
    exit 1
  fi
}
#==============================================================#
# 达梦数据库异步追踪日志
#==============================================================#
function conf_sqllog() {
  # 定义sqllog路径
  local db_dir
  # 定义sqllog.ini 创建文件的函数
  function create_ini_file() {
    local db_dir="$1"
    # 创建 sqllog.ini 配置文件
    local config
    config=$(
      cat <<EOF
BUF_TOTAL_SIZE          = 204800         #SQLs Log Buffer Total Size(K)(1024~1024000)
BUF_SIZE                = 10240          #SQLs Log Buffer Size(K)(50~409600)
BUF_KEEP_CNT            = 20             #SQLs Log buffer keeped count(1~100)
[SLOG_ALL]
FILE_PATH    = $db_dir
PART_STOR    = 0
SWITCH_MODE  = 2
SWITCH_LIMIT = 128
ASYNC_FLUSH  = 1
FILE_NUM     = 200
ITEMS        = 0
SQL_TRACE_MASK  = 1
MIN_EXEC_TIME = 0
USER_MODE   = 0
USERS       =
EXECTIME_PREC_FLAG = 0
[SLOG_ERROR]
SQL_TRACE_MASK = 23
FILE_PATH      = $db_dir
[SLOG_DDL]
SQL_TRACE_MASK = 3
[SLOG_LONG_SQL]
SQL_TRACE_MASK = 25
MIN_EXEC_TIME = 60000
EOF
    )
    # 使用su切换用户并执行命令
    run_cmd su - dmdba <<-EOSQLLOG
printf "%s" "$config" | tee "${db_dir}.ini" > /dev/null
EOSQLLOG
  }

  # 判断安装模式
  if [[ $dm_install_mode =~ ^(dsc|dscm)$ ]]; then
    # 如果安装模式为"dsc"，则创建每个节点的SQL日志目录
    for ((x = 0; x < ${#all_pubip_arr[@]}; x++)); do
      ep_name="${dsc_ep_name}$(printf "%02d" $((x + 1)))"
      # 针对每个IP地址，创建相应的SQL日志目录
      db_dir="$data_dir/$dsc_db_name/$(lower "$ep_name")_config/sqllog"
      run_cmd mkdir -p "$db_dir"                # 创建目录及子目录
      run_cmd chown -R dmdba:dinstall "$db_dir" # 给目录赋予适当的权限
      create_ini_file "$db_dir"
    done
  else
    # 如果不是"dsc"安装模式，创建一个默认的SQL日志目录
    db_dir="$data_dir/$db_name/sqllog"
    create_ini_file "$db_dir"
    # 修改配置文件中的路径为备份目录
    run_cmd sed -i "s#$data_dir#$backup_dir#g" "${db_dir}.ini"
    # 创建备份目录并设置权限
    run_cmd mkdir -p "$backup_dir/$db_name/sqllog"
    run_cmd chown -R dmdba:dinstall "$backup_dir/$db_name/sqllog"
  fi
}
