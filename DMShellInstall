#==============================================================#
# Get UUID
#==============================================================#
function get_wwid() {
  local wwid
  local disk_name=$1
  if [[ "$disk_name" =~ ^/dev ]]; then
    # 如果设备是磁盘设备路径，执行处理
    case $os_version in
    6)
      wwid=$(/sbin/scsi_id -g -u -d "$disk_name")
      ;;
    *)
      if [[ "$disk_name" =~ [0-9]$ ]]; then
        wwid=$(udevadm info --query=all --name="$disk_name" | awk -F'=' '/ID_PART_ENTRY_UUID/ {print $2}')
      else
        wwid=$(/usr/lib/udev/scsi_id -g -u -d "$disk_name")
      fi
      ;;
    esac
  else
    # 如果不是磁盘设备，使用 dmsetup 获取 WWID
    wwid=$(dmsetup info -c | grep "$disk_name" | awk '{print $8}')
  fi
  # 输出 WWID
  echo "$wwid"
}
#==============================================================#
# 检查磁盘是否具有唯一wwid
#==============================================================#
function check_disk() {
  # 存储参数
  # shellcheck disable=SC2207
  local disk_para=($([[ $dm_install_mode == "dsc" ]] && echo "-dcd -vod" || echo "-dcd") ${log_disk:+-lod} ${arch_disk:+-ard} "-dad")
  # 存储磁盘信息
  declare -A disk_para_str=(
    ["-dcd"]="$dcr_disk"
    ["-vod"]="$vote_disk"
    ["-ard"]="$arch_disk"
    ["-lod"]="$log_disk"
    ["-dad"]="$data_disk"
  )
  # 磁盘uuid值
  local disk_uuid
  # 存储磁盘uuid对应的磁盘
  declare -A disk_uuid_map
  # 开始校验磁盘
  for para in "${disk_para[@]}"; do
    IFS=',' read -r -a disks <<<"${disk_para_str[$para]}"
    printf "\n"
    color_printf white "校验 ${disks[*]} 磁盘，请等待！！！"
    for disk in "${disks[@]}"; do
      disk_uuid=$(get_wwid "$disk") # 获取磁盘UUID
      # 如果UUID为空，打印错误信息并退出
      if [[ -z "$disk_uuid" ]]; then
        CHECK_FLAG=0
        printf "\n"
        color_printf red "请检查参数 [ $para ] 的值 $disk 是否正确！"
      fi
      # 检查是否有重复的磁盘UUID
      if [[ -n "${disk_uuid_map[$disk_uuid]}" ]]; then
        CHECK_FLAG=0
        printf "\n"
        color_printf red "在参数 [ $para ] 中检测到重复的磁盘：$disk"
      fi
      # 如果没有重复，将UUID存入关联数组
      disk_uuid_map["$disk_uuid"]="$disk"
      # 使用 dd 命令清空磁盘
      if [[ $format_disk == "Y" ]]; then
        dd if=/dev/zero of="$disk" bs=100M count=10 >/dev/null 2>&1 &
        wait # 等待所有清空操作完成
      fi
    done
  done
}
#==============================================================#
# 判断磁盘冗余模式和磁盘数量关系
