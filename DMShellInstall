function si_dmarch() {
  # 如果归档目录不存在，则创建它
  if [[ ! -d $arch_dir ]]; then
    run_cmd mkdir -m 755 -p "$arch_dir"
    run_cmd chown -R dmdba:dinstall "$arch_dir"
  fi
  # 为特定数据库实例创建归档目录
  db_arch_dir="$arch_dir/$db_name"
  if [[ ! -d $db_arch_dir ]]; then
    run_cmd mkdir -m 755 -p "$db_arch_dir"
    run_cmd chown -R dmdba:dinstall "$db_arch_dir"
  fi
  # 生成配置归档日志的SQL脚本
  conf_arch_sql=$(
    cat <<-EOF
set echo off
set timing off
set feedback off
set lineshow off
ALTER DATABASE MOUNT;
ALTER DATABASE ARCHIVELOG;
ALTER DATABASE ADD ARCHIVELOG 'DEST=$db_arch_dir, TYPE=LOCAL, FILE_SIZE=$log_size, SPACE_LIMIT=$space_limit';
ALTER DATABASE OPEN;
select arch_mode from v\$database;
SELECT arch_name,
        arch_dest,
        arch_file_size,
        arch_space_limit
  FROM v\$dm_arch_ini;
exit;
EOF
  )
  # 将SQL脚本写入文件
  conf_arch_file="${scripts_dir}/conf_arch.sql"
  run_cmd printf "%s\n" "$conf_arch_sql" | run_cmd tee "$conf_arch_file" >/dev/null
  run_cmd chown dmdba:dinstall "$conf_arch_file"
}
#配置dsc归档脚本
function dsc_dmarch() {
  local dsc_dmarch_file="${scripts_dir}/conf_arch.sql"
  # 添加归档日志目的地到数据库
  function arch_log_dest() {
    local dest_type=$1         # 归档日志目的地类型（本地或远程）
    local dest_path=$2         # 归档日志目的地路径
    local file_size=$3         # 归档日志文件大小
    local space_limit_value=$4 # 归档日志文件空间限制
    local incoming_path=$5     # 可选的远程归档日志目的地的传入路径
    run_cmd su - dmdba <<-DMARCH
      cat <<-EOF>>"$dsc_dmarch_file"
ALTER DATABASE ADD ARCHIVELOG 'DEST = $dest_path, TYPE = $dest_type, FILE_SIZE = $file_size, SPACE_LIMIT = $space_limit_value ${incoming_path:+, INCOMING_PATH = $incoming_path}';
EOF
DMARCH
  }
  # 初始化配置文件
  function init_config() {
    run_cmd su - dmdba <<-DMARCH
      cat <<-EOF>"$dsc_dmarch_file"
ALTER DATABASE MOUNT;
ALTER DATABASE ARCHIVELOG;
EOF
DMARCH
  }
  # 处理本地归档目的地
  function loc_arch_dest() {
    local dest_path=$1
    arch_log_dest "local" "$dest_path" "$log_size" "$space_limit_value"
  }
  # 处理远程归档目的地
  function rem_arch_dest() {
    local asm_path=$1
    for ((x = 1; x <= ${#all_pubip_arr[@]}; x++)); do
      # shellcheck disable=SC2155
      if [[ $x -ne $node_num ]]; then
        local remote_dest_path="$(upper "${dsc_ep_name}")$(printf "%02d" "$x")"
        arch_log_dest "REMOTE" "$remote_dest_path" "$log_size" "$space_limit_value" "$asm_path/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$x")"
      fi
    done
  }
  # 根据配置动态计算归档日志空间限制
  if [[ -z $arch_disk && $is_local_arch = "N" ]]; then
    space_limit_value=$space_limit
  else
    space_limit_value=$(awk "BEGIN { printf \"%.0f\", ($space_limit - 10240) / ${#all_pubip_arr[@]} }")
  fi
  # 初始化归档配置
  init_config
  # 配置归档目的地
  lastIndex=$((${#asm_disk_arr[@]} - 1))
  if [[ -z $arch_disk ]]; then
    if [[ $is_local_arch = "N" ]]; then
      loc_arch_dest "+$(upper "${asm_disk_arr[$lastIndex]}")/dmarch/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$node_num")"
      rem_arch_dest "+$(upper "${asm_disk_arr[$lastIndex]}")/dmarch"
    else
      loc_arch_dest "$arch_dir/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$node_num")"
      rem_arch_dest "$arch_dir/$dsc_db_name"
    fi
  else
    asm_path="+$(upper "${asm_disk_arr[$((lastIndex - 1))]}")/dmarch"
    if [[ $is_local_arch = "N" ]]; then
      loc_arch_dest "$asm_path/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$node_num")"
      rem_arch_dest "$asm_path"
    else
      loc_arch_dest "$asm_path/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$node_num")"
      rem_arch_dest "$asm_path"
      loc_arch_dest "$arch_dir/$dsc_db_name/${dsc_ep_name}$(printf "%02d" "$node_num")"
    fi
  fi
  run_cmd su - dmdba <<-DMARCH
    cat <<-EOF>>$dsc_dmarch_file
ALTER DATABASE OPEN;
exit;
EOF
DMARCH
  chown dmdba:dinstall "$dsc_dmarch_file"
}
