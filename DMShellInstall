#==============================================================#
# 备份系统文件
#==============================================================#
function bak_file() {
  # 获取第一个传入参数作为要备份的文件路径
  local file_path=$1
  # 如果文件存在则备份
  if check_file "$file_path"; then
    # 检查文件中是否包含 "# DMBegin" 字符串
    if [[ $(run_cmd grep -E -c "# DMBegin" "$file_path") -eq 0 ]]; then
      # 如果不包含，则使用 cp 命令备份该文件，并附加 .original 后缀
      run_cmd /bin/cp -fpr "$file_path"{,.original} >/dev/null 2>&1
    else
      # 如果文件中包含 "# DMBegin" 字符串，则先备份当前文件，再恢复原始文件
      # 备份当前文件，将其保存为原来的名称加上当前时间戳的形式
      run_cmd /bin/cp -fpr "$file_path"{,."$current"} >/dev/null 2>&1
      # 恢复原始文件，将其替换回原始的备份文件
      run_cmd /bin/cp -fpr "$file_path"{.original,} >/dev/null 2>&1
    fi
  else
    # 文件不存在，创建一个空的 .original 文件
    run_cmd touch "$file_path".original
  fi
}
#==============================================================#
# 获取操作系统类型和版本
#==============================================================#
function define_os_flag() {
  local or_file=/etc/os-release
  local sr_file=/etc/system-release
  local rr_file=/etc/redhat-release
  # 获取OS类型
  if [[ -f "${or_file}" ]]; then
    os_type=$(awk <"${or_file}" -F= '/^ID=/ { gsub("\"", "", $2); print $2 }')
    pretty_name=$(sed -n 's/^PRETTY_NAME="\(.*\)"/\1/p' "${or_file}")
  else
    os_type=$(grep <"$([ -f ${sr_file} ] && echo ${sr_file} || echo ${rr_file})" -oP '^[A-Za-z]+')
    pretty_name=$(cat "${sr_file}")
  fi
  # 定义 os_version
  libc_version=$(ldd --version | head -n 1 | awk '{print $NF}' | cut -d '.' -f 2)
  # 根据 libc_version 获取 os_version
  declare -A os_version_map=(
    ["6"]="12-16"
    ["7"]="17-27"
    ["8"]="28-33"
    ["9"]="34-38"
    ["10"]="39-99" # redhat10 是 ldd (GNU libc) 2.39
  )
  for value in "${!os_version_map[@]}"; do
    IFS="-" read -r start end <<<"${os_version_map[$value]}"
    if ((libc_version >= start && libc_version <= end)); then
      os_version="$value"
      break
    fi
  done
  # 校验是否匹配到 os_version
  if [[ -z "$os_version" ]]; then
    color_printf red "当前操作系统版本 [ $pretty_name ] 不在脚本支持列表中，如有需要请联系开发者适配！"
    exit 1
  fi
  # 定义OS标记
  case $os_type in
  Red | CentOS | rhel | centos | ol | rocky | anolis)
    if [[ $os_version -eq 8 || $os_version -eq 9 ]]; then
      os_flag=OS2
    fi
    ;;
  uos)
    # 判断UOS系统是1060a版本还是1060e版本
    if [[ "$(grep </etc/issue -oE "0a|0e")" == "0a" ]]; then
      os_flag="OS2"
    else
      os_flag="OS3"
    fi
    ;;
  openEuler)
    os_flag=OS4
    ;;
  *)
    os_flag=OS1
    ;;
  esac
  # 获取主机上所有IP地址
  IFS=' ' read -ra current_ips <<<"$(hostname -I)"
  # 遍历当前 IP 地址数组，并检查是否匹配过滤后的 IP 地址
  for current_ip in "${current_ips[@]}"; do
    if [[ "${as_pubip_arr[*]}" =~ $current_ip ]]; then
      os_flag_value=1 # 如果匹配，更新 os_flag_value 为 1
    elif [[ "${sy_pubip_arr[*]}" =~ $current_ip ]]; then
      os_flag_value=2
    fi
  done
}
