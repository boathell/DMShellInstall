#==============================================================#
# 函数用于执行命令，如果不是root用户，则添加sudo前缀
#==============================================================#
# shellcheck disable=SC2032
function run_cmd() {
  if [[ $debug_flag =~ [Yy] ]]; then
    # 开启调试模式，输出每个执行的命令
    set -x
  fi
  # 如果当前用户不是 root，则使用 sudo 执行命令
  if [ "$EUID" -ne 0 ]; then
    sudo "$@"
  else
    "$@"
  fi
  # 获取命令的退出状态
  local exit_status=$?
  if [[ $debug_flag =~ [Yy] ]]; then
    # 关闭调试模式
    set +x
  fi
  # 返回退出状态
  return $exit_status
}
#==============================================================#
# 日志输出颜色
#==============================================================#
function color_printf() {
  # 定义颜色映射表
  declare -A color_map=(
    ["red"]='\033[31m'
    ["green"]='\033[1;32m'
    ["yellow"]='\033[33m'
    ["blue"]='\033[34m'
    ["light_blue"]='\033[1;94m'
    ["white"]='\033[37m'
    ["reset"]='\033[0m' # 重置颜色
  )
  # 如果颜色不存在，使用默认白色
  local color=${color_map[$1]:-${color_map["white"]}}
  local text1="${2:-}"
  local text2="${3:-}"
  local text3="${4:-}"
  # 打印格式化文本
  printf "${color}%-15s %-25s %-30s${color_map["reset"]}\n" "$text1" "$text2" "$text3"
}
#==============================================================#
# 打印日志
#==============================================================#
function log_print() {
  local message="$1"
  # 打印日志框架和内容
  local color="green"
  local length=60
  # shellcheck disable=SC2155
  local string=$(printf "=%.0s" $(seq 1 $length))
  printf "\n"
  color_printf "$color" "#${string}#"
  color_printf "$color" "${message}"
  color_printf "$color" "#${string}#"
  printf "\n"
}
#==============================================================#
# 判断参数值为空或者-开头
#==============================================================#
function checkpara_NULL() {
  if [[ -z $2 || $2 == -* ]]; then
    printf "\n"
    color_printf red "请检查参数 [ $1 ] 的值是否为空！"
    printf "\n"
    exit 1
  fi
}
#==============================================================#
# 判断参数值是否为 Y/N
#==============================================================#
function checkpara_YN() {
  if ! [[ $2 =~ ^[YyNn]$ ]]; then
    ARG_CHECK_FLAG=0
    printf "\n"
    color_printf red "请检查参数 [ $1 ] 的值是否为 [Y/N]."
    printf "\n"
  fi
}
#==============================================================#
# 判断值是否包含
#==============================================================#
function checkpara_validity() {
  local option_name=$1
  local option_value=$2
  local valid_values=("${@:3}")
  if ! [[ " ${valid_values[*]} " =~ $option_value ]]; then
    ARG_CHECK_FLAG=0
    printf "\n"
    color_printf red "请检查参数 [ $option_name ] 的值 \"$option_value\" 是否为 [ ${valid_values[*]} ] 中的一个！"
    printf "\n"
  fi
}
#==============================================================#
# 操作系统命令检验
#==============================================================#
function command_check() {
  # 校验系统命令，如果命令不存在为真，标记不存在
  function check_command_existence() {
    local command_name=$1
    # 如果命令不存在，则输出错误信息
    if ! run_cmd command -v "$command_name" >/dev/null 2>&1; then
      ARG_CHECK_FLAG=0
      printf "\n"
      color_printf red "Error: $command_name 命令未找到！"
      printf "\n"
    fi
  }
  # 定义命令参数
  declare -a commands=("dirname" "mount" "tar")
  for shell_c in "${commands[@]}"; do
    check_command_existence "$shell_c"
  done
}
