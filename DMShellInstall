set echo off
set timing off
set lineshow off
set feedback off
set pagesize 1000
DECLARE
    v_compatible_mode NUMBER; -- 用于存储COMPATIBLE_MODE的值
    TYPE t_command_array IS TABLE OF VARCHAR2(1000); -- 定义一个命令数组类型
    v_commands t_command_array; -- 用于存储命令的数组
BEGIN
