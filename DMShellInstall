# 修改数据库参数文件
#==============================================================#
function dw_dmini() {
  # 主备库配置 dm.ini 参数
  if [[ $node_num -eq 1 ]]; then
    log_print "数据守护主库配置参数"
    color_printf blue "主库配置 dm.ini 参数："
  else
    log_print "数据守护备库配置参数"
    color_printf blue "备库配置 dm.ini 参数："
  fi
  printf "\n"
  # 定义更新 dm.ini 参数的函数
  function update_dm_ini() {
    local pattern="$1"
    local replacement="$2"
    run_cmd su - dmdba <<-DM
sed -i -e "s/$pattern/$replacement/g" $data_dir/$db_name/dm.ini
DM
  }
  # 定义配置项和对应的替换值
  declare -A config_updates=(
    ["ALTER_MODE_STATUS\s*=\s*0"]="ALTER_MODE_STATUS = 1"
    ["ENABLE_OFFLINE_TS\s*=\s*1"]="ENABLE_OFFLINE_TS = 2"
    ["MAL_INI\s*=\s*0"]="MAL_INI = 1"
    ["ARCH_INI\s*=\s*0"]="ARCH_INI = 1"
  )
  # 遍历配置项并更新
  for pattern in "${!config_updates[@]}"; do
    update_dm_ini "$pattern" "${config_updates[$pattern]}"
  done
  # 特殊条件下，更新 TIMER_INI 参数
  if [[ -n "$as_public_ip" ]] && { [ "$os_flag_value" -eq 0 ] || [ "$node_num" -eq 1 ]; }; then
    update_dm_ini "TIMER_INI\s*=\s*0" "TIMER_INI = 1"
  fi
  # 打印更新后的 dm.ini 参数
  run_cmd grep -e "ALTER_MODE_STATUS" -e "ENABLE_OFFLINE_TS" -e "MAL_INI" -e "ARCH_INI" <"$data_dir"/"$db_name"/dm.ini
  # 打印异步备库的 TIMER_INI 参数
  if [[ -n "$as_public_ip" ]] && { [ "$os_flag_value" -eq 0 ] || [ "$node_num" -eq 1 ]; }; then
    run_cmd grep -e "TIMER_INI" <"$data_dir"/"$db_name"/dm.ini
  fi
}
