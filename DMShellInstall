#==============================================================#
# 传参前校验函数
#==============================================================#
function pre_para_check() {
  local need_install_media=1
  # 检查脚本路径是否是 /soft，建议放置数据库包和脚本
  if [[ ${software_dir} != "/soft" ]]; then
    printf "\n"
    color_printf yellow "建议将数据库安装包和脚本放到 /soft 目录并在该目录下执行脚本，否则可能会失败！"
  fi
  # 检查当前目录是否为 root 根目录、/root 或 $env_dm_home
  if [[ ${software_dir} == "/" || ${software_dir} == "/root" || ${software_dir} == "$env_dm_home" ]]; then
    printf "\n"
    color_printf red "脚本和软件包位置不能是 /、/root 或 $env_dm_home!"
    printf "\n"
    exit 1
  fi
  # 仅初始化数据库且软件已安装时，不强制要求提供安装介质
  if [[ $only_init_db =~ [Yy] ]] && check_dm_software_installed; then
    need_install_media=0
  fi
  # 检查是否存在 DMInstall.bin 文件或通过 -di 参数指定安装包
  if [[ $need_install_media -eq 1 ]] && ! [[ -f ${software_dir}/${dm_iso_name} ]] && ! check_file "${software_dir}/DMInstall.bin"; then
    printf "\n"
    if [[ $only_init_db =~ [Yy] ]]; then
      color_printf red "当前为仅初始化数据库实例，但未检测到已安装的达梦软件，且当前目录不存在 DMInstall.bin 安装包，也未通过 -di 参数指定，无法继续安装！"
    else
      color_printf red "当前目录不存在 DMInstall.bin 安装包，也未通过 -di 参数指定，无法继续安装！"
    fi
    printf "\n"
    exit 1
  fi
  # 检查脚本名称是否为 DMShellInstall
  if [[ "$(basename "$0")" != "DMShellInstall" ]]; then
    printf "\n"
    color_printf red "脚本名称必须为 DMShellInstall，已退出!"
    printf "\n"
    exit 1
  fi
  # 检查当前用户是否为 root 或是否有 NOPASSWD: ALL 权限
  if [[ "$(id -u)" -ne 0 ]]; then
    if sudo -l 2>/dev/null | grep -qE '.(ALL).*NOPASSWD:.*ALL'; then
      printf "\n"
      color_printf yellow "当前用户是非 root 用户，但具有 (ALL) NOPASSWD: ALL 权限，继续执行脚本。"
      return
    else
      printf "\n"
      color_printf red "当前用户是非 root 用户，且没有 (ALL) NOPASSWD: ALL 权限，已退出!"
      exit 1
    fi
  fi
}
#==============================================================#
# 程序入口
#==============================================================#
function main() {
  # 定义脚本名称
  script_name="sh ${software_dir}/$(basename "$0")"
  # 将命令行参数和脚本名称输出到日志文件
  node_cmd=$(printf "\n%s %s\n" "$script_name" "$(printf "%q " "$@" | tr -s ' ')" | tee -a "${dminstalllog}")
  # 打印提示信息
  script_print
  # 检验脚本传入参数
  check_para "$@"
  # 获取操作系统版本
  define_os_flag
  # 校验服务器是否安装了必备工具
  command_check
  # 如果需要安装 sshpass，则进行安装
  if [[ $only_install_sshpass =~ [Yy] ]]; then
    install_sshpass
  fi
  # 如果是单节点安装，执行以下操作
  if ((node_num == 1)); then
    # 创建操作系统用户
    if [[ $only_create_user =~ [Yy] ]]; then
      create_os_user
    fi
    # 参数预检查
    pre_para_check
  fi
  # 如果参数校验失败，退出安装
  if [[ $ARG_CHECK_FLAG -eq 0 ]]; then
    printf "\n"
    color_printf red "参数校验不通过！请检查屏幕上输出的异常信息或查看${dminstalllog}文件。"
    printf "\n"
    exit 1
  fi
  # 选择数据库安装模式
  install_mode
  # 去除登录提示和密码复杂度检查
  remove_pwd_com
  # 校验IP和磁盘信息（仅在特定模式下）
  [[ $dm_install_mode =~ ^(datawatch|dsc|dscm)$ ]] && validate_ip_disk
  # 开始安装数据库
  begin_install_dmdb "$@"
  # 配置节点信息
  if [[ $dm_install_mode =~ ^(datawatch|dsc|dscm)$ ]]; then
    if [[ $node_num -eq 1 ]]; then
      log_print "配置节点: ${all_pubip_arr[0]}"
      color_printf yellow "节点 ${all_pubip_arr[0]} 开始配置:"
    fi
  fi
  # 打印系统信息
  print_sysinfo
  # 数据库安装过程
  conf_os_env
  # 仅配置操作系统环境
  if [[ $only_conf_os == "N" ]]; then
    install_db_soft
    # 仅安装数据库
    if [[ $install_until_db == "N" ]]; then
      # 根据安装模式选择不同的安装方法
      case $dm_install_mode in
      "single")
        prepare_si_node # 安装单机数据库
        ;;
      "datawatch")
        [[ $node_num -ne -1 ]] && prepare_si_node # 安装数据守护集群
        prepare_dw_node                           # 配置数据守护节点
        ;;
      "dsc" | "dscm")
        prepare_dsc_node # 安装DSC集群
        ;;
      esac
      # 生成安装报告
      if [[ $node_num -eq 1 ]]; then
        generate_install_report
      fi
      # 重启服务器
      if [[ $node_num -eq 1 ]]; then
        # 修改口令策略
        mod_db_mess
        # 重启数据库
        restart_hosts
      fi
    else
      # 如果仅安装数据库，不执行后续操作，直接重启
      printf "\n"
      restart_hosts
    fi
  else
    # 如果只配置操作系统环境，直接重启
    printf "\n"
    restart_hosts
  fi
}
